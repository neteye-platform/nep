        "nx-c-centreon_ibm_storwize_ssh": {
            "arguments": {
                "--component": {
                    "description": "Which component to check (Default: '.*'). Can be: 'array', 'drive', 'enclosure', 'enclosurebattery', 'enclosurecanister',             'enclosurepsu', 'host', 'portfc', 'portsas', 'vdisk', 'node', 'quorum', 'mdisk', 'systemstats'.",
                    "value": "$nx_centreon_ibm_storwize_ssh_component_list$"
                },
                "--critical": {
                    "value": "$nx_centreon_ibm_storwize_ssh_critical$"
                },
                "--critical-usage": {
                    "value": "$nx_centreon_ibm_storwize_ssh_critical_usage$"
                },
                "--filter": {
                    "description": "Exclude some parts (comma seperated list) (Example: --filter=host --filter=enclosurecanister) Can also exclude specific instance: --filter=host,10",
                    "repeat_key": true,
                    "value": "$nx_centreon_ibm_storwize_ssh_filter$"
                },
                "--filter-name": {
                    "description": "Filter pool by name (can be a regexp)",
                    "value": "$nx_centreon_ibm_storwize_ssh_filter_name$"
                },
                "--mode": {
                    "value": "$nx_centreon_ibm_storwize_ssh_mode_list$"
                },
                "--warning": {
                    "value": "$nx_centreon_ibm_storwize_ssh_warning$"
                },
                "--warning-usage": {
                    "value": "$nx_centreon_ibm_storwize_ssh_warning_usage$"
                }
            },
            "command": "\/usr\/lib\/centreon\/plugins\/centreon_ibm_storwize_ssh.pl",
