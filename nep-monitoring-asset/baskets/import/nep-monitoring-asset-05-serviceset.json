{
    "ServiceSet": {
        "nx-ss-neteye-asset-state": {
            "assign_filter": "host.vars.nx_enable_nep_ss=true&!\"nx-ss-neteye-asset-state\"=host.vars.nx_nep_ss_to_exclude&\"neteye-asset\"=host.vars.neteye_modules&(\"nx-ht-neteye-mainsystem-master\"=host.templates|\"nx-ht-neteye-subsystem-master\"=host.templates)",
            "description": "Service Set providing common monitoring for OCS and GLPI inventory",
            "object_name": "nx-ss-neteye-asset-state",
            "object_type": "template",
            "services": {
                "Asset Duplicates": {
                    "fields": [],
                    "imports": [
                        "nx-st-agentless-inventory",
                        "nx-st-type-custom"
                    ],
                    "notes": "Checks OCS and GLPI duplicate assets",
                    "object_name": "Asset Duplicates",
                    "object_type": "object",
                    "vars": {
                        "nx_inventory_command": "duplicates",
                        "nx_inventory_critical": "30",
                        "nx_inventory_warning": "10"
                    }
                },
                "Asset Old not up-to-date": {
                    "fields": [],
                    "imports": [
                        "nx-st-agentless-inventory",
                        "nx-st-type-custom"
                    ],
                    "notes": "Check Old not up-to-date assets in OCS and GLPI",
                    "object_name": "Asset Old not up-to-date",
                    "object_type": "object",
                    "vars": {
                        "nx_inventory_command": "age",
                        "nx_inventory_critical": "60",
                        "nx_inventory_warning": "45"
                    }
                },
                "Timer GLPI automatic actions": {
                    "fields": [],
                    "imports": [
                        "nx-st-agent-linux-systemd-timer",
                        "nx-st-type-custom"
                    ],
                    "object_name": "Timer GLPI automatic actions",
                    "object_type": "object",
                    "vars": {
                        "systemd_timer_critical": "240",
                        "systemd_timer_service_name": "glpi-execute-automatic-actions",
                        "systemd_timer_timer_name": "glpi-execute-automatic-actions",
                        "systemd_timer_warning": "120"
                    }
                },
                "Timer OCS GLPI full sync": {
                    "fields": [],
                    "imports": [
                        "nx-st-agent-linux-systemd-timer",
                        "nx-st-type-custom"
                    ],
                    "object_name": "Timer OCS GLPI full sync",
                    "object_type": "object",
                    "vars": {
                        "systemd_timer_critical": "1200",
                        "systemd_timer_service_name": "ocs-glpi-full-sync",
                        "systemd_timer_timer_name": "ocs-glpi-full-sync",
                        "systemd_timer_warning": "1020"
                    }
                }
            }
        },
        "nx-ss-neteye-asset-disk-state": {
            "assign_filter": "host.vars.nx_enable_nep_ss=true&!\"nx-ss-neteye-asset-state\"=host.vars.nx_nep_ss_to_exclude&\"neteye-asset\"=host.vars.neteye_modules&host.vars.nx_neteye_cluster=true&(\"nx-ht-neteye-mainsystem-master\"=host.templates|\"nx-ht-neteye-subsystem-master\"=host.templates)",
            "description": "Service Set providing common monitoring for OCS and GLPI inventory",
            "object_name": "nx-ss-neteye-asset-disk-state",
            "object_type": "template",
            "services": {
                "Disk GLPI Free space": {
                    "fields": [],
                    "imports": [
                        "nx-st-agent-linux-byssh-disk-free-space",
                        "nx-st-type-custom"
                    ],
                    "object_name": "Disk GLPI Free space",
                    "object_type": "object",
                    "vars": {
                        "by_ssh_address": "httpd.neteyelocal",
                        "by_ssh_logname": "monitoring",
                        "disk_single_ereg_path": "/neteye/shared/glpi"
                    }
                },
                "Disk OCS Reports Free space": {
                    "fields": [],
                    "imports": [
                        "nx-st-agent-linux-byssh-disk-free-space",
                        "nx-st-type-custom"
                    ],
                    "object_name": "Disk OCS Reports Free space",
                    "object_type": "object",
                    "vars": {
                        "by_ssh_address": "httpd.neteyelocal",
                        "by_ssh_logname": "monitoring",
                        "disk_single_ereg_path": "/neteye/shared/ocsinventory-ocsreports"
                    }
                },
                "Disk OCS Server Free space": {
                    "fields": [],
                    "imports": [
                        "nx-st-agent-linux-byssh-disk-free-space",
                        "nx-st-type-custom"
                    ],
                    "object_name": "Disk OCS Server Free space",
                    "object_type": "object",
                    "vars": {
                        "by_ssh_address": "httpd.neteyelocal",
                        "by_ssh_logname": "monitoring",
                        "disk_single_ereg_path": "/neteye/shared/ocsinventory-server"
                    }
                }
            }
        }
    }
}