{
    "Command": {
        "nx-c-check-ups-health": {
            "arguments": {
                "--authpassword": {
                    "value": "$snmp_auth_passphrase$"
                },
                "--authprotocol": {
                    "value": "$snmp_authprotocol$"
                },
                "--community": {
                    "description": "Community",
                    "value": "$snmp_community$"
                },
                "--criticalx": {
                    "description": "The extended critical thresholds e.g. --criticalx db_msdb_free_pct=6: to override the threshold",
                    "value": "$ups_criticalx$"
                },
                "--hostname": {
                    "description": "Hostname",
                    "value": "$host.address$"
                },
                "--mode": {
                    "description": "Mode ",
                    "value": "$nx_ups_mode$"
                },
                "--privpassword": {
                    "description": "The password for authPriv security level",
                    "value": "$snmp_priv_password$"
                },
                "--privprotocol": {
                    "description": "The private protocol for SNMPv3 (des|aes|aes128|3des|3desde)",
                    "value": "$snmp_privprotocol$"
                },
                "--protocol": {
                    "value": "$snmp_version$"
                },
                "--username": {
                    "value": "$snmp_user$"
                },
                "--warningx": {
                    "description": "The extended warning thresholds e.g. --warningx db_msdb_free_pct=6: to override the threshold",
                    "value": "$ups_warningx$"
                }
            },
            "command": "PluginContribDir + \/check_ups_health",
            "disabled": false,
            "fields": [],
            "imports": [],
            "is_string": null,
            "methods_execute": "PluginCheck",
            "object_name": "nx-c-check-ups-health",
            "object_type": "object",
            "timeout": null,
            "vars": {},
            "zone": null
        }
    }
}