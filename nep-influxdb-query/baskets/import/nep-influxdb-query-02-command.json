{
    "Command": {
        "nx-c-centreon-influxdb-query": {
            "arguments": {
                "--aggregation": {
                    "description": "Set the aggregation on metric values (Can be: 'average', 'min', 'max', 'sum') (Default: 'average').",
                    "value": "$nx_centreon_influxdb_query_aggregation$"
                }
            },
            "command": null,
            "disabled": false,
            "fields": [],
            "imports": [
                "nx-ct-centreon-influxdb-query"
            ],
            "is_string": null,
            "methods_execute": "PluginCheck",
            "object_name": "nx-c-centreon-influxdb-query",
            "object_type": "object",
            "timeout": null,
            "vars": {},
            "zone": null
        }
    },
    "CommandTemplate": {
        "nx-ct-centreon-influxdb": {
            "arguments": {
                "--critical-http-status": {
                    "description": "Threshold critical for http response code.",
                    "value": "$nx_centreon_influxdb_critical_http_status$"
                },
                "--curl-opt": {
                    "description": "Set CURL Options (--curl-opt=\"CURLOPT_SSL_VERIFYPEER => 0\" --curl-opt=\"CURLOPT_SSLVERSION => CURL_SSLVERSION_TLSv1_1\" ).",
                    "repeat_key": true,
                    "value": "$nx_centreon_influxdb_curl_opt$"
                },
                "--hostname": {
                    "description": "Remote hostname or IP address.",
                    "value": "$nx_centreon_influxdb_hostname$"
                },
                "--http-backend": {
                    "description": "Set the backend used (Default: 'lwp') For curl: --http-backend=curl",
                    "value": "$nx_centreon_influxdb_backend$"
                },
                "--http-peer-addr": {
                    "description": "Set the address you want to connect (Useful if hostname is only a vhost. no ip resolve)",
                    "value": "$nx_centreon_influxdb_http_peer_addr$"
                },
                "--insecure": {
                    "description": "Insecure SSL connections.",
                    "set_if": "$nx_centreon_influxdb_insecure$",
                    "set_if_format": "string"
                },
                "--password": {
                    "description": "Specify password for authentication.",
                    "value": "$nx_centreon_influxdb_password$"
                },
                "--port": {
                    "description": "Port used (Default: 8086)",
                    "value": "$nx_centreon_influxdb_port$"
                },
                "--proto": {
                    "description": "Specify https if needed (Default: 'http')",
                    "value": "$nx_centreon_influxdb_proto$"
                },
                "--proxypac": {
                    "description": "Proxy pac file (can be an url or local file)",
                    "value": "$nx_centreon_influxdb_proxypac$"
                },
                "--proxyurl": {
                    "description": "Proxy URL",
                    "value": "$nx_centreon_influxdb_proxyurl$"
                },
                "--ssl": {
                    "description": "Set SSL version (--ssl=TLSv1).",
                    "value": "$nx_centreon_influxdb_ssl$"
                },
                "--ssl-opt": {
                    "description": "Set SSL Options (--ssl-opt=\"SSL_version => TLSv1\"  --ssl-opt=\"SSL_verify_mode => SSL_VERIFY_NONE\").",
                    "repeat_key": true,
                    "value": "$nx_centreon_influxdb_ssl_opt$"
                },
                "--timeout": {
                    "description": "Set timeout in seconds (Default: 10).",
                    "value": "$nx_centreon_influxdb_timeout$"
                },
                "--unknown-http-status": {
                    "description": "Threshold unknown for http response code. (Default: '%{http_code} < 200 or %{http_code} >= 300')",
                    "value": "$nx_centreon_influxdb_unknown_http_status$"
                },
                "--username": {
                    "description": "Specify username for authentication.",
                    "value": "$nx_centreon_influxdb_username$"
                },
                "--warning-http-status": {
                    "description": "Threshold warning for http response code.",
                    "value": "$nx_centreon_influxdb_warning_http_status$"
                }
            },
            "command": "\/usr\/lib\/centreon\/plugins\/centreon_influxdb.pl --plugin database::influxdb::plugin",
            "disabled": false,
            "fields": [],
            "imports": [
                "nx-ct-centreon-plugin-base"
            ],
            "is_string": null,
            "methods_execute": "PluginCheck",
            "object_name": "nx-ct-centreon-influxdb",
            "object_type": "template",
            "timeout": "15",
            "vars": {},
            "zone": null
        },
        "nx-ct-centreon-influxdb-query": {
            "arguments": {
                "--critical-status": {
                    "description": "Set critical threshold for status (Default: ''). Can use special variables like %{instance} and any other labels you set through --query.",
                    "value": "$nx_centreon_influxdb_query_critical_status$"
                },
                "--instance": {
                    "description": "Set the instance label on which the results should be calculate for (Example: --instance='name').  The instance label must be the same label as the \"GROUP BY\" keyword.",
                    "value": "$nx_centreon_influxdb_query_instance$"
                },
                "--mode": "query",
                "--multiple-output": {
                    "description": "Set the global output in case everything is fine for multiple instances (Example: --multiple-output='All instance values are ok').",
                    "value": "$nx_centreon_influxdb_query_multiple_output$"
                },
                "--output": {
                    "description": "Set the output for each instances (Example: --output='Object %{instance} value is {label}').",
                    "value": "$nx_centreon_influxdb_query_output$"
                },
                "--query": {
                    "description": "Set a InfluxQL query. Query option must be like --query='label,query'. Query must contain an \"AS\" keyword to rename the column of the selected data, and must match the label. (Example: --query='mymetric,SELECT the_data AS \"mymetric\" FROM \"database\".\"retention\".\"measurement\" GROUP BY \"instance\"')",
                    "value": "$nx_centreon_influxdb_query_query$"
                },
                "--warning-status": {
                    "description": "Set warning threshold for status (Default: ''). Can use special variables like %{instance} and any other labels you set through --query.",
                    "value": "$nx_centreon_influxdb_query_warning_status$"
                }
            },
            "command": "\/usr\/lib\/centreon\/plugins\/centreon_influxdb.pl --plugin database::influxdb::plugin",
            "disabled": false,
            "fields": [],
            "imports": [
                "nx-ct-centreon-influxdb"
            ],
            "is_string": null,
            "methods_execute": "PluginCheck",
            "object_name": "nx-ct-centreon-influxdb-query",
            "object_type": "template",
            "timeout": null,
            "vars": {},
            "zone": null
        }
    }
}