{
    "ServiceSet": {
        "nx-ss-network-centreon-ubiquiti-standard": {
            "assign_filter": "host.vars.nx_enable_nep_ss=true&!\"nx-ss-network-centreon-ubiquiti-standard\"=host.vars.nx_nep_ss_to_exclude&\"nx-ht-network-switch-snmp\"=host.templates&host.vars.nx_hardware_vendor=%22ubiquiti%22",
            "description": "Service Set providing monitoring for Ubiquiti switch (Edge)\r\n - CPU Load (1m; 5m)\r\n - Hardware Health\r\n - Memory Usage",
            "object_name": "nx-ss-network-centreon-ubiquiti-standard",
            "object_type": "template",
            "services": {
                "CPU Load": {
                    "fields": [],
                    "imports": [
                        "nx-st-agentless-snmp-centreon-ubiquiti-edge-cpu",
                        "nx-st-type-custom"
                    ],
                    "object_name": "CPU Load",
                    "object_type": "object",
                    "vars": {
                        "nx_centreon_ubiquiti_cpu_crit1m": "90",
                        "nx_centreon_ubiquiti_cpu_crit5m": "90",
                        "nx_centreon_ubiquiti_cpu_warn1m": "80",
                        "nx_centreon_ubiquiti_cpu_warn5m": "80"
                    }
                },
                "HW Health": {
                    "fields": [],
                    "imports": [
                        "nx-st-agentless-snmp-centreon-ubiquiti-edge-harwdare",
                        "nx-st-type-custom"
                    ],
                    "object_name": "HW Health",
                    "object_type": "object",
                    "vars": {
                        "nx_centreon_snmp_critical": "temperature,.*,70",
                        "nx_centreon_snmp_warning": "temperature,.*,50"
                    }
                },
                "Memory Usage": {
                    "fields": [],
                    "imports": [
                        "nx-st-agentless-snmp-centreon-ubiquiti-edge-memory",
                        "nx-st-type-custom"
                    ],
                    "object_name": "Memory Usage",
                    "object_type": "object",
                    "vars": {
                        "nx_centreon_ubiquiti_mem_crit": "90",
                        "nx_centreon_ubiquiti_mem_warn": "80"
                    }
                }
            }
        }
    }
}