                }
            ],
            "originalId": "7",
            "provider_class": "Icinga\\Module\\Director\\Import\\ImportSourceSql",
            "settings": {
                "column_cache": "name, endpoint_name, zone_name, child_zone_name",
                "query": "SELECT CONCAT(e.object_name, '!', c.object_name) AS NAME,\r\n       e.object_name AS endpoint_name,\r\n       z.object_name AS zone_name,\r\n       c.object_name AS child_zone_name\r\nFROM icinga_endpoint e\r\nINNER JOIN icinga_zone z ON e.zone_id = z.id\r\nINNER JOIN icinga_zone c ON z.id = c.parent_id;",
                "resource": "director"
            },
            "source_name": "nx-is-neteye-infrastructure-zones"
        },
