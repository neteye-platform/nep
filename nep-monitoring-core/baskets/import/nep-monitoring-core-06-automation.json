                {
                    "description": null,
                    "priority": "7",
                    "property_name": "is_subsystem",
                    "provider_class": "Icinga\\Module\\Director\\PropertyModifier\\PropertyModifierMakeBoolean",
                    "settings": {
                        "on_invalid": "null"
                    },
                    "target_property": null
                },
                {
                    "description": null,
                    "priority": "8",
                    "property_name": "master_node",
                    "provider_class": "Icinga\\Module\\Director\\PropertyModifier\\PropertyModifierMakeBoolean",
                    "settings": {
                        "on_invalid": "null"
                    },
                    "target_property": null
                }
            ],
            "originalId": "4",
            "provider_class": "Icinga\\Module\\Director\\Import\\ImportSourceSql",
            "settings": {
                "column_cache": "endpoint_name, endpoint_host, endpoint_port, log_duration, zone_id, zone_name, disabled, parent_zone_name, master_node, is_clustered, is_subsystem, siblings",
                "query": "SELECT \r\n  e.object_name AS endpoint_name, \r\n  (\r\n    IF(\r\n      e.host IS NULL, e.object_name, e.host\r\n    )\r\n  ) AS endpoint_host, \r\n  e.port AS endpoint_port, \r\n  e.log_duration AS log_duration, \r\n  z.id AS zone_id, \r\n  z.object_name AS zone_name, \r\n  e.disabled AS disabled, \r\n  p.object_name AS parent_zone_name, \r\n  (\r\n    IF (\r\n      (\r\n        SELECT \r\n          COUNT(*) \r\n        FROM \r\n          icinga_zone \r\n        WHERE \r\n          (\r\n            id = z.id \r\n            AND object_name LIKE '%-master'\r\n          ) \r\n          OR (\r\n            id = z.id \r\n            AND object_name LIKE 'master'\r\n          )\r\n      )>= 1, \r\n      'true', \r\n      'false'\r\n    )\r\n  ) AS master_node, \r\n  (\r\n    IF (\r\n      (\r\n        SELECT \r\n          COUNT(*) \r\n        FROM \r\n          icinga_zone \r\n        WHERE \r\n          (\r\n            parent_id = e.zone_id \r\n            AND object_name LIKE '%cluster-satellite%'\r\n          ) \r\n          OR (\r\n            id = e.zone_id \r\n            AND object_name LIKE '%cluster-satellite%'\r\n          )\r\n      )>= 1, \r\n      'true', \r\n      'false'\r\n    )\r\n  ) AS is_clustered, \r\n  (\r\n    IF (\r\n      (\r\n        SELECT \r\n          COUNT(*) \r\n        FROM \r\n          icinga_zone \r\n        WHERE \r\n          (\r\n            id = z.id \r\n            AND object_name LIKE 'ness-%'\r\n          )\r\n      )>= 1, \r\n      'true', \r\n      'false'\r\n    )\r\n  ) AS is_subsystem, \r\n  (\r\n    SELECT \r\n      COUNT(*) \r\n    FROM \r\n      icinga_endpoint \r\n    WHERE \r\n      zone_id = e.zone_id\r\n  ) AS siblings \r\nFROM \r\n  icinga_endpoint e \r\n  INNER JOIN icinga_zone z ON e.zone_id = z.id \r\n  LEFT JOIN icinga_zone p ON z.parent_id = p.id;\r\n",
                "resource": "director"
            },
            "source_name": "nx-is-neteye-infrastructure-endpoints"
        },
