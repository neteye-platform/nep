{
    "Command": {
        "nx-c-alyvix-service-poller": {
            "arguments": {
                "-E": {
                    "description": "Name of the Tenant owning the Testcases to check",
                    "value": "$nx_alyvix_service_tenant$"
                },
                "-H": {
                    "description": "Name of the Alyvix node as reported by NetEye Alyvix Module",
                    "value": "$nx_alyvix_service_node_name$"
                },
                "-M": {
                    "description": "FQDN of the NetEye Master Instance providing Icinga2 and Icingaweb2",
                    "value": "$nx_alyvix_service_neteye_master_hostname$"
                },
                "-N": {
                    "description": "Name of the Host Object containing the Service Objects of the Testcases to monitor",
                    "value": "$nx_alyvix_service_host_object$"
                },
                "-R": {
                    "description": "Node name to use in Alyvix report URLs",
                    "value": "$nx_alyvix_service_node_name$"
                },
                "-p": {
                    "description": "Icinga2 credential used to set the state of the Service Objects referring the Testcases to monitor",
                    "value": "$nx_alyvix_service_icinga_username$:$nx_alyvix_service_icinga_password$"
                },
                "-t": {
                    "description": "Default time after Testcase data are considered outdated. This usually means the test case is not running anymore.",
                    "value": "$nx_alyvix_service_default_testcase_timeout$"
                },
                "-w": {
                    "description": "Icingaweb2 credential used to get the JTW Token to query Alyvix module for Testcase status",
                    "value": "$nx_alyvix_service_icingaweb_username$:$nx_alyvix_service_icingaweb_password$"
                }
            },
            "command": "PluginContribDir + /check_alyvix3_testcases.pl -J -V 3",
            "fields": [],
            "methods_execute": "PluginCheck",
            "object_name": "nx-c-alyvix-service-poller",
            "object_type": "object",
            "vars": {
                "nx_alyvix_service_tenant": "$host.vars.neteye_tenant$"
            }
        },
        "nx-c-check-alyvix3-server": {
            "arguments": {
                "-H": {
                    "description": "Alyvix3 Server hostname/ip",
                    "value": "$alyvix3_server_name$"
                },
                "-T": {
                    "description": "Alyvix3 Testcase name",
                    "value": "$alyvxi3_testcase_name$"
                },
                "-U": {
                    "description": "Alyvix3 Testcase user",
                    "value": "$alyvix3_testcase_user$"
                },
                "-t": {
                    "description": "Alyvix3 Testcase values older then timeout gives UNKNOWN (default: 0)",
                    "value": "$alyvix3_server_timeout$"
                }
            },
            "command": "PluginContribDir + /check_alyvix3_testcase.pl",
            "fields": [],
            "methods_execute": "PluginCheck",
            "object_name": "nx-c-check-alyvix3-server",
            "object_type": "object"
        }
    }
}
