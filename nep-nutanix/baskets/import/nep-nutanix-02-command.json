    "CommandTemplate": {
        "nx-ct-centreon-plugin-snmp-nutanix": {
            "arguments": {
                "--filter-counters": {
                    "description": "Only display some counters (regexp can be used)",
                    "value": "$nx_centreon_nutanix_snmp_filter_counters$"
                },
                "--hostname": {
                    "type": "Function",
                    "body": "var cvms=macro(\"$host.vars.nx_nutanix_cluster_cvm$\")\r\nvar available_cvms = []\r\nfor (var cvm in cvms) {\r\ncvm_host=get_host(cvm)\r\nvar cvm_state=cvm_host.state\r\nif(cvm_state == 0) {\r\navailable_cvms.add(cvm_host.address)\r\n}\r\n}\r\nif (available_cvms.len() > 0) {\r\nreturn available_cvms[random() % available_cvms.len()]\r\n} \r\nreturn cvms[random() % cvms.len()]"
                }
            },
            "command": "/usr/lib/centreon/plugins/centreon_nutanix_snmp.pl --plugin cloud::nutanix::snmp::plugin",
            "fields": [],
            "imports": [
                "nx-ct-centreon-plugin-snmp"
            ],
            "methods_execute": "PluginCheck",
            "object_name": "nx-ct-centreon-plugin-snmp-nutanix",
            "object_type": "template",
            "uuid": "ffe95c7b-25a3-4394-80e6-7bee66beca90"
        }
    }
