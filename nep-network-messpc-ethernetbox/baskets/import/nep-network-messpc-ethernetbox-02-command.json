{
    "Command": {
        "nx-c-check-pcmeasure2": {
            "arguments": {
                "-H": {
                    "description": "Hostname or IP-address of the EthernetBox device",
                    "value": "$host.address$"
                },
                "-S": {
                    "description": "Sensor Port you want to check.",
                    "value": "$pcmeasure2_sensor_port$"
                },
                "-c": {
                    "description": "CRITICAL threshold. See -w.",
                    "value": "$pcmeasure2_critical$"
                },
                "-l": {
                    "description": "Label for performance data",
                    "value": "$pcmeasure2_label$"
                },
                "-w": {
                    "description": "WARNING threshold. Example: -w 18:22 returns OK if result is between 18 and 22, WARNING otherwise.",
                    "value": "$pcmeasure2_warning$"
                }
            },
            "command": "PluginContribDir + \/check_pcmeasure2.pl",
            "disabled": false,
            "fields": [],
            "imports": [],
            "is_string": null,
            "methods_execute": "PluginCheck",
            "object_name": "nx-c-check-pcmeasure2",
            "object_type": "object",
            "timeout": null,
            "vars": {},
            "zone": null
        }
    }
}