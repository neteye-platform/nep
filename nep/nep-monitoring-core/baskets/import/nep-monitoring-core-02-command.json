        "nx-c-check-icinga-duplicated-ips": {
            "arguments": {
                "--critical": "1",
                "--database": "director",
                "--mode": "sql",
                "--name": "SELECT COUNT(*) AS dupli_ips FROM (SELECT COUNT(*) FROM icinga_host WHERE address NOT IN ('localhost', '127.0.0.1') AND zone_id = (SELECT id FROM icinga_zone WHERE object_name = '$nx_zone_name$') GROUP BY address HAVING COUNT(*)>1) dupli_ips;",
                "--name2": "ip_duplicated",
                "--environment": {
                    "repeat_key": true,
                    "value": "NAGIOS__SERVICEMYSQL_MYCNF=/neteye/local/icinga2/data/spool/icinga2/.my.cnf"
                },
                "--hostname": "mariadb.neteyelocal"
            },
            "command": null,
