{
    "Command": {
        "nx-c-check-inventory": {
            "arguments": {
                "-C": {
                    "description": "specify the kind of check to perform",
                    "value": "$nx_inventory_command$",
                    "order": "1"
                },
                "-I": {
                    "description": " Ignore items marked as deleted",
                    "set_if": "$nx_inventory_ignore_deleted$",
                    "set_if_format": "string",
                    "order": "2"
                },
                "-c": {
                    "description": "specify the number of days an asset item has not to be updated before returning a critical. Default: 20",
                    "value": "$nx_inventory_critical$",
                    "order": "4"
                },
                "-w": {
                    "description": "specify the number of days an asset item has not to be updated before returning a warning. Default: 10",
                    "value": "$nx_inventory_warning$",
                    "order": "3"
                },
                "-x": {
                    "description": "\"host1,host2,neteye_.*,...\"     exclude those host name from the check results     Expression is taken as case insensitive Perl Regular Expression",
                    "value": "$nx_inventory_exclude$",
                    "order": "5"
                }
            },
            "command": "PluginContribDir + \/check_assetmanagement.pl",
            "disabled": false,
            "fields": [],
            "imports": [],
            "is_string": null,
            "methods_execute": "PluginCheck",
            "object_name": "nx-c-check-inventory",
            "object_type": "object",
            "timeout": "60",
            "vars": {},
            "zone": null
        },
        "nx-c-check-systemd-timer": {
            "arguments": {
                "(no key)": {
                    "description": "<service name>",
                    "skip_key": true,
                    "value": "$systemd_timer_service_name$",
                    "order": "1"
                },
                "(no key.2)": {
                    "description": "<timer name>",
                    "skip_key": true,
                    "value": "$systemd_timer_timer_name$",
                    "order": "2"
                },
                "(no key.3)": {
                    "description": "<time in seconds between runs that is not warning> ",
                    "skip_key": true,
                    "value": "$systemd_timer_warning$",
                    "order": "3"
                },
                "(no key.4)": {
                    "description": "<time in seconds between runs that is not critical> ",
                    "skip_key": true,
                    "value": "$systemd_timer_critical$",
                    "order": "4"
                }
            },
            "command": "PluginContribDir + \/check_systemd_timer",
            "disabled": false,
            "fields": [],
            "imports": [],
            "is_string": null,
            "methods_execute": "PluginCheck",
            "object_name": "nx-c-check-systemd-timer",
            "object_type": "object",
            "timeout": null,
            "vars": {},
            "zone": null
        }
    }
}