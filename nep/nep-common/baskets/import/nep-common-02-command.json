        "nx-c-powershell-check-process": {
            "arguments": {
                "-Arguments": {
                    "description": "Arguments to the script",
                    "repeat_key": true,
                    "required": false,
                    "skip_key": true,
                    "value": "$powershell_scriptarguments$",
                    "order": "5"
                },
                "-Command": {
                    "skip_key": true,
                    "value": "$$output = ''; $$result = (Get-Process -ErrorAction SilentlyContinue -Name '$powershell_process_name$' | Select-Object -Property ProcessName | Group-Object -Property ProcessName); if ($$result.count -eq 0) { $$output += '$powershell_process_name$ | CRITICAL - No instance are running!'; $$code = 2 } else { if ($$result.count -eq 1) {$$output += $$result.name + ' | OK - ' + $$result.count.ToString() + ' instance are running'; $$code = 0}; if ($$result.count -gt 1) { $$output += $$result.name + ' | WARNING - ' + $$result.count.ToString() + ' instance are running'; $$code = 1} }; Write-Output $$output; exit($$code);",
                    "order": "4"
                },
                "-ExecutionPolicy": {
                    "description": "Set the default execution policy for the session.",
                    "value": "$powershell_executionpolicy$",
                    "order": "2"
                },
                "-NoProfile": {
                    "description": "Do not load the PowerShell profile. No pre-defined functions will be available. When setting up a scheduled job, using -NoProfile can be a quick way to document the fact that nothing special in the profile is needed. It also ensures that any future profile changes will not affect the job.",
                    "set_if": "$powershell_noprofile$",
                    "skip_key": true,
                    "value": "-NoProfile",
                    "order": "1"
                },
                "-Noninteractive": {
                    "description": "Don't present an interactive prompt to the user.",
                    "set_if": "$powershell_noninteractive$",
                    "skip_key": true,
                    "value": "-Noninteractive",
                    "order": "3"
                }
            },
            "command": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
            "disabled": false,
            "fields": [],
            "imports": [],
            "is_string": null,
            "methods_execute": "PluginCheck",
            "object_name": "nx-c-powershell-check-process",
            "object_type": "object",
            "timeout": "60",
            "vars": {
                "powershell_executionpolicy": "Bypass",
                "powershell_noninteractive": false,
                "powershell_noprofile": true
            },
            "zone": null
        },
        "nx-c-check-netstat": {
            "arguments": {
                "-c": {
                    "description": "Comma separated. Critical level(s) (if more than one attrib, must have multiple values). Critical values can have the same prefix modifiers as warning (see above) except '^'",
                    "required": true,
                    "value": "$nx_netstat_critical$",
                    "order": "4"
                },
                "-f": {
                    "description": "Collects metrics",
                    "repeat_key": false,
                    "set_if": "$nx_netstat_metrics$",
                    "set_if_format": "string",
                    "skip_key": true,
                    "value": "-f",
                    "order": "6"
                },
                "-p": {
                    "description": "Comma separated. Which tcp ports (attributes) to check. The value here can be either numeric or name that would be come from /etc/services. The value should be prefixed with: > : check outgoing TCP connections, < : check incoming TCP connections (default). Special value of '>@' or just '>' allow to specify that you want to check on total number of TCP connections (this is reported in perfomance data as 'all_out').",
                    "required": true,
                    "value": "$nx_netstat_port$",
                    "order": "1"
                },
                "-r": {
                    "description": "protocol=TCP|TCP6|UDP|UDP6 Query the specified protocol, default is TCP. Combinations of protocols will be supported in the future, but not right now",
                    "value": "$nx_netstat_protocol$",
                    "order": "2"
                },
                "-s": {
                    "description": "Report only sessions in specific state. The most common states used here are \"ESTABLISHED' and 'CLOSE_WAIT'",
                    "value": "$nx_netstat_state$",
                    "order": "5"
                },
                "-w": {
                    "description": "Comma separated. Warning level(s) - usually numbers (same number of values specified as number of attributes). Warning values can have the following prefix modifiers: > : warn if data is above this value (default), < : warn if data is below this value, = : warn if data is equal to this value, ! : warn if data is not equal to this value, ~ : do not check this data (must not be followed by number), ^ : this disables checks that warning is less than critical",
                    "required": true,
                    "value": "$nx_netstat_warning$",
                    "order": "3"
                }
            },
            "command": "PluginContribDir + /check_netstat.pl",
            "fields": [

            ],
            "methods_execute": "PluginCheck",
            "object_name": "nx-c-check-netstat",
            "object_type": "object"
        },
