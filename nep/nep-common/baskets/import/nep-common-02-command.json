        "nx-c-powershell-script": {
            "arguments": {
                "-Arguments": {
                    "description": "Arguments to the script",
                    "repeat_key": true,
                    "required": false,
                    "skip_key": true,
                    "value": "$powershell_scriptarguments$",
                    "order": "5"
                },
                "-ExecutionPolicy": {
                    "description": "Set the default execution policy for the session.",
                    "value": "$powershell_executionpolicy$",
                    "order": "2"
                },
                "-File": {
                    "description": "Execute a script file. The filename is required. If the file\/pathname contains spaces then surround with double quotation marks:  -file \"path to\\your script.ps1\"",
                    "required": true,
                    "value": "$powershell_scriptfile$",
                    "order": "4"
                },
                "-NoProfile": {
                    "description": "Do not load the PowerShell profile. No pre-defined functions will be available. When setting up a scheduled job, using -NoProfile can be a quick way to document the fact that nothing special in the profile is needed. It also ensures that any future profile changes will not affect the job.",
                    "set_if": "$powershell_noprofile$",
                    "skip_key": true,
