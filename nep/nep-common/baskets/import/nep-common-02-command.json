    "Command": {
        "nx-c-check-icinga-startup-log-linux": {
            "arguments": {
                "-c": {
                    "required": true,
                    "value": "[ -f $nx_icinga_datadir$\/api\/zones-stage\/startup.log ] && { echo \"ERROR: last icinga2 reload failed.\"; exit $nx_plugin_return_state$; } || { echo \"OK: icinga2 configuration loaded correctly.\"; exit 0; }",
                    "order": "1"
                }
            },
            "command": "\/bin\/bash --noprofile --norc",
            "disabled": false,
            "fields": [],
            "imports": [],
