          "metricColumn": "none",
          "rawQuery": true,
          "rawSql": "SELECT\r\n   $__timeGroupAlias(sh.state_time,$__interval),\r\n   CASE sh.state\r\n    WHEN 0 THEN IF(o.objecttype_id=1, 'Host to UP',   'Service to OK')\r\n    WHEN 1 THEN IF(o.objecttype_id=1, 'Host to DOWN', 'Service to WARNING')\r\n    WHEN 2 THEN IF(o.objecttype_id=1, 'Host to DOWN', 'Service to CRITICAL')\r\n    WHEN 3 THEN IF(o.objecttype_id=1, 'Host to DOWN', 'Service to UNKNOWN')\r\n    ELSE IF(o.objecttype_id=1, 'Host to N/A', 'Service to N/A')\r\n   END AS metric,\r\n   COUNT(sh.state) AS value\r\nFROM\r\n   icinga_statehistory sh\r\n   INNER JOIN icinga_objects o ON sh.object_id = o.object_id AND sh.instance_id = o.instance_id\r\nWHERE\r\n   $__timeFilter(sh.state_time)\r\n   AND o.objecttype_id IN(1, 2)\r\n   AND sh.state_type IN(${state_types})\r\n   AND (\r\n     CASE sh.state\r\n       WHEN 0 THEN IF(o.objecttype_id=1, 'Host to UP',   'Service to OK')\r\n       WHEN 1 THEN IF(o.objecttype_id=1, 'Host to DOWN', 'Service to WARNING')\r\n       WHEN 2 THEN IF(o.objecttype_id=1, 'Host to DOWN', 'Service to CRITICAL')\r\n       WHEN 3 THEN IF(o.objecttype_id=1, 'Host to DOWN', 'Service to UNKNOWN')\r\n       ELSE IF(o.objecttype_id=1, 'Host to N/A', 'Service to N/A')\r\n     END\r\n    ) IN(${state_transitions})\r\nGROUP BY 1,2\r\nORDER BY $__timeGroup(sh.state_time,$__interval)",
