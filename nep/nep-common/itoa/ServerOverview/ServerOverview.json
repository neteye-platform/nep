            "rawQuery": true,
            "rawSql": "Select\r\n    icinga.icinga_services.display_name,\r\n    icinga.icinga_servicestatus.current_state,\r\n    max(icinga.icinga_servicestatus.last_state_change) last_state_change,\r\n    icinga.icinga_servicestatus.output\r\nFrom\r\n    icinga.icinga_servicestatus Inner Join\r\n    icinga.icinga_services On icinga.icinga_services.service_object_id = icinga.icinga_servicestatus.service_object_id\r\n    Inner Join\r\n    icinga.icinga_objects On icinga.icinga_objects.object_id = icinga.icinga_services.host_object_id\r\nwhere icinga.icinga_objects.name1='$hostname' and icinga.icinga_servicestatus.current_state between 1 and 2\r\ngroup by icinga.icinga_services.display_name",
