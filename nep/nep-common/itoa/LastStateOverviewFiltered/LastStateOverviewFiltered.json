      "targets": [
        {
          "format": "table",
          "group": [],
          "metricColumn": "none",
          "rawQuery": true,
          "rawSql": "SELECT\n\t-- sh.state_time AS 'State time Normal',\n\tconvert_tz(sh.state_time, 'Europe/Rome','Etc/UTC') AS 'State time',\n\t'Host' AS 'Object type',\n\t-- if(length(o.name1) > 20, concat(left(o.name1, 20),'    (...)'), o.name1) AS 'Object name',\n\to.name1 as 'Object name',\n\to.name1 AS 'Hostname',\n\t-- sh.state AS State,\n\tCASE sh.state\n    WHEN 0 THEN 'Host UP'\n    WHEN 1 THEN 'Host DOWN'\n    WHEN 2 THEN 'Host DOWN'\n    WHEN 3 THEN 'Host DOWN'\n    ELSE 'Host N/A'\n   END AS State,\n\tCASE sh.state\n   WHEN 0 THEN '10'\n   WHEN 1 THEN '11'\n   WHEN 2 THEN '12'\n   ELSE 'Host N/A'\n   END AS StateCode,\n\tIF(sh.state_type=0, 'Soft', 'Hard') AS 'State type',\n\tCASE sh.state_type\n   WHEN 0 THEN '30'\n   ELSE '31'\n   END as 'StateTypeCode',\n\tCONCAT(sh.current_check_attempt,'/',sh.max_check_attempts) AS 'Check attempt',\n\t-- sh.output AS 'Plugin Output',\n\tif(length(sh.output) > 50, concat(left(sh.output, 50),'    (...)'), sh.output) AS 'Plugin Output',\n\tsh.check_source AS 'Check source'\nFROM\n\ticinga_statehistory sh\n\tINNER JOIN icinga_objects o ON sh.object_id = o.object_id\n  -- INNER JOIN icinga_customvariables cv_lista ON cv_lista.object_id = o.object_id\n  -- INNER JOIN icinga_customvariables cv_cliente ON cv_cliente.object_id = o.object_id\nWHERE\n  $__timeFilter(sh.state_time)\n\tAND o.is_active = 1\n\tAND o.objecttype_id = 1\n  -- AND cv_lista.varname = 'lista' AND cv_lista.varvalue IN(${lista})\n  -- AND cv_cliente.varname = 'cliente' AND cv_cliente.varvalue IN(${clienti})\n  AND (\n     CASE sh.state\n        WHEN 0 THEN 'Host UP'\n        WHEN 1 THEN 'Host DOWN'\n        WHEN 2 THEN 'Host DOWN'\n        WHEN 3 THEN 'Host DOWN'\n    ELSE 'Host N/A'\n     END\n    ) IN(${state})\n\nUNION\n\nSELECT\n\t-- sh.state_time AS 'State time Normal',\n  convert_tz(sh.state_time, 'Europe/Rome','Etc/UTC') AS 'State time',\n  'Service' AS 'Object type',\n  CONCAT(os.name1, ' __ ', os.name2) AS 'Object name',\n  os.name1 AS 'Hostname',\n  -- sh.state AS State,\n  CASE sh.state\n   WHEN 0 THEN 'Service OK'\n    WHEN 1 THEN 'Service WARNING'\n    WHEN 2 THEN 'Service CRITICAL'\n    WHEN 3 THEN 'Service UNKNOWN'\n    ELSE 'Service N/A'\n   END AS State,\n   CASE sh.state\n   WHEN 0 THEN '20'\n   WHEN 1 THEN '21'\n   WHEN 2 THEN '22'\n   WHEN 3 THEN '23'\n   ELSE 'Service N/A'\n   END AS StateCode,\n  -- IF(sh.state_type = 0, 'Soft', 'Hard') AS 'State type',\n   CASE sh.state_type\n      WHEN 0 THEN 'Soft'\n      ELSE 'Hard'\n    END AS 'State type',\n  CASE sh.state_type\n   WHEN 0 THEN '30'\n   ELSE '31'\n   END as 'StateTypeCode',\n  CONCAT(sh.current_check_attempt,'/',sh.max_check_attempts) AS 'Check attempt',\n  -- sh.output AS 'Plugin Output',\n  if(length(sh.output) > 50, concat(left(sh.output, 50),'    (...)'), sh.output) AS 'Plugin Output',\n  sh.check_source AS 'Check source'\nFROM icinga_statehistory sh\n  INNER JOIN icinga_services s ON sh.object_id = s.service_object_id\n  INNER JOIN icinga_objects os ON s.service_object_id = os.object_id\n  INNER JOIN icinga_objects oh ON s.host_object_id = oh.object_id\n  -- INNER JOIN icinga_customvariables cv_lista ON cv_lista.object_id = oh.object_id\n  -- INNER JOIN icinga_customvariables cv_cliente ON cv_cliente.object_id = oh.object_id\nWHERE\n  $__timeFilter(sh.state_time)\n  AND os.is_active = 1\n  AND oh.is_active = 1\n  -- AND cv_lista.varname = 'lista' AND cv_lista.varvalue IN(${lista})\n  -- AND cv_cliente.varname = 'cliente' AND cv_cliente.varvalue IN(${clienti})\n  AND (\n    CASE sh.state\n      WHEN 0 THEN 'Service OK'\n      WHEN 1 THEN 'Service WARNING'\n      WHEN 2 THEN 'Service CRITICAL'\n      WHEN 3 THEN 'Service UNKNOWN'\n      ELSE 'Service N/A'\n    END\n    )  IN(${state})\n    AND (\n    CASE sh.state_type\n      WHEN 0 THEN 'Soft'\n      ELSE 'Hard'\n    END \n    ) IN(${state_types}) ",
          "refId": "A",
          "select": [
