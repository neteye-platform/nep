{
    "Command": {
        "nx-c-centreon-cisco-standard-cpu": {
            "arguments": {
                "--critical-average-1m": "$nx_centreon_cisco_cpu_crit1m$",
                "--critical-average-5m": "$nx_centreon_cisco_cpu_crit5m$",
                "--mode": "cpu",
                "--warning-average-1m": "$nx_centreon_cisco_cpu_warn1m$",
                "--warning-average-5m": "$nx_centreon_cisco_cpu_warn5m$"
            },
            "command": "/usr/lib/centreon/plugins/centreon_cisco_standard_snmp.pl",
            "fields": [],
            "imports": [
                "nx-ct-centreon-plugin-snmp"
            ],
            "methods_execute": "PluginCheck",
            "object_name": "nx-c-centreon-cisco-standard-cpu",
            "object_type": "object",
            "uuid": "6927048f-8231-4c62-98f8-db9537941a01"
        },
        "nx-c-centreon-cisco-standard-env": {
            "arguments": {
                "--add-name-instance": {
                    "description": "Add literal description for instance value (used in filter, absent-problem and threshold options)",
                    "set_if": "$nx_centreon_cisco_environment_addname$",
                    "set_if_format": "string"
                },
                "--component": {
                    "description": "Which component to check (Default: '.*'). Can be: 'fan', 'psu', 'temperature', 'voltage', 'module', 'physical', 'sensor'",
                    "value": "$nx_centreon_cisco_environment_component$",
                    "order": "2"
                },
                "--critical": {
                    "description": "Set critical threshold for temperatures, voltages, sensors (syntax: type,regexp,threshold) Example: --critical='temperature,.*,40'",
                    "value": "$nx_centreon_cisco_environment_critical$",
                    "repeat_key": true,
                    "order": "5"
                },
                "--filter": {
                    "description": "Exclude the items given as a comma-separated list (example: --filter=fan --filter=psu). You can also exclude items from specific instances: --filter=fan,1",
                    "value": "$nx_centreon_cisco_environment_filter$",
                    "order": "3"
                },
                "--mode": {
                    "description": "Check environment (Power Supplies, Fans, Temperatures, Voltages, Modules, Physical Entities)",
                    "value": "environment",
                    "order": "1"
                },
                "--warning": {
                    "description": "Set warning threshold for temperatures, voltages, sensors (syntax: type,regexp,threshold) Example: --warning='temperature,.*,30'",
                    "value": "$nx_centreon_cisco_environment_warning$",
                    "repeat_key": true,
                    "order": "4"
                }
            },
            "command": "/usr/lib/centreon/plugins/centreon_cisco_standard_snmp.pl",
            "fields": [],
            "imports": [
                "nx-ct-centreon-plugin-snmp"
            ],
            "methods_execute": "PluginCheck",
            "object_name": "nx-c-centreon-cisco-standard-env",
            "object_type": "object",
            "uuid": "98e33f58-54d3-44b0-b5a6-e6d5f4053da8"
        },
        "nx-c-centreon-cisco-standard-interfaces": {
            "arguments": {
                "--add-cast": {
                    "description": "Check interface cast.",
                    "set_if": "$nx_centreon_cisco_interfaces_add_cast$",
                    "set_if_format": "string"
                },
                "--add-duplex-status": {
                    "description": "Check duplex status (with --warning-status and --critical-status).",
                    "set_if": "$nx_centreon_cisco_interfaces_add_duplex_status$",
                    "set_if_format": "string"
                },
                "--add-err-disable": {
                    "description": "Check error disable (with --warning-status and --critical-status).",
                    "set_if": "$nx_centreon_cisco_interfaces_add_err_disable$",
                    "set_if_format": "string"
                },
                "--add-errors": {
                    "description": "Check interface errors.",
                    "set_if": "$nx_centreon_cisco_interfaces_add_errors$",
                    "set_if_format": "string"
                },
                "--add-global": {
                    "description": "Check global port statistics (By default if no --add-* option is set).",
                    "set_if": "$nx_centreon_cisco_interfaces_add_global$",
                    "set_if_format": "string"
                },
                "--add-speed": {
                    "description": "Check interface speed.",
                    "set_if": "$nx_centreon_cisco_interfaces_add_speed$",
                    "set_if_format": "string"
                },
                "--add-status": {
                    "description": "Check interface status.",
                    "set_if": "$nx_centreon_cisco_interfaces_add_status$",
                    "set_if_format": "string"
                },
                "--add-traffic": {
                    "description": "Check interface traffic.",
                    "set_if": "$nx_centreon_cisco_interfaces_add_traffic$",
                    "set_if_format": "string"
                },
                "--add-volume": {
                    "description": "Check interface data volume between two checks (not supposed to be graphed, useful for BI reporting).",
                    "set_if": "$nx_centreon_cisco_interfaces_add_volume$",
                    "set_if_format": "string"
                },
                "--check-metrics": {
                    "description": "If the expression is true, metrics are checked (Default: '%{opstatus} eq \"up\"').",
                    "set_if": "$nx_centreon_cisco_interfaces_check_metrics$",
                    "set_if_format": "string"
                },
                "--critical-in-bcast": {
                    "description": "Set critical threshold for in-bcast",
                    "value": "$nx_centreon_cisco_interfaces_critical_in_bcast$"
                },
                "--critical-in-crc": {
                    "description": "Set critical threshold for in-crc",
                    "value": "$nx_centreon_cisco_interfaces_critical_in_crc$"
                },
                "--critical-in-discard": {
                    "description": "Set critical threshold for in-discard",
                    "value": "$nx_centreon_cisco_interfaces_critical_in_discard$"
                },
                "--critical-in-error": {
                    "description": "Set critical threshold in-error",
                    "value": "$nx_centreon_cisco_interfaces_critical_in_error$"
                },
                "--critical-in-traffic": {
                    "description": "Set critical threshold for in-traffic",
                    "value": "$nx_centreon_cisco_interfaces_critical_in_traffic$"
                },
                "--critical-out-bcast": {
                    "description": "Set critical threshold for out-bcast",
                    "value": "$nx_centreon_cisco_interfaces_critical_out_bcast$"
                },
                "--critical-out-discard": {
                    "description": "Set critical threshold for out-discard",
                    "value": "$nx_centreon_cisco_interfaces_critical_out_discard$"
                },
                "--critical-out-error": {
                    "description": "Set critical threshold for out-error",
                    "value": "$nx_centreon_cisco_interfaces_critical_out_error$"
                },
                "--critical-out-traffic": {
                    "description": "Set critical threshold for out-traffic",
                    "value": "$nx_centreon_cisco_interfaces_critical_out_traffic$"
                },
                "--critical-status": {
                    "description": "Set critical threshold for status (Default: '%{admstatus} eq \"up\" and %{opstatus} ne \"up\"'). Can used special variables like: %{admstatus}, %{opstatus}, %{duplexstatus}, %{errdisable}, %{display}",
                    "value": "$nx_centreon_cisco_interfaces_critical_status$"
                },
                "--force-counters32": {
                    "description": "Force to use 32 bits counters (even in snmp v2c and v3). Should be used when 64 bits counters are buggy.",
                    "set_if": "$nx_centreon_cisco_interfaces_force_counters_32$",
                    "set_if_format": "string"
                },
                "--interface": {
                    "description": "Set the interface (number expected) ex: 1,2,... (empty means 'check all interface').",
                    "value": "$nx_centreon_cisco_interfaces_interface$"
                },
                "--mode": "interfaces",
                "--name": {
                    "description": "Allows to use interface name with option --interface instead of interface oid index (Can be a regexp)",
                    "set_if": "$nx_centreon_cisco_interfaces_name$",
                    "set_if_format": "string"
                },
                "--speed": {
                    "description": "Set interface speed for incoming/outgoing traffic (in Mb).",
                    "value": "$nx_centreon_cisco_interfaces_speed$"
                },
                "--speed-in": {
                    "description": "Set interface speed for incoming traffic (in Mb).",
                    "value": "$nx_centreon_cisco_interfaces_speed_in$"
                },
                "--speed-out": {
                    "description": "Set interface speed for outgoing traffic (in Mb).",
                    "value": "$nx_centreon_cisco_interfaces_speed_out$"
                },
                "--units-cast": {
                    "description": "Units of thresholds for communication types (default: 'percent_delta') ('percent_delta', 'percent', 'delta', 'deltaps', 'counter').",
                    "value": "$nx_centreon_cisco_interfaces_units_cast$"
                },
                "--units-errors": {
                    "description": "Units of thresholds for errors/discards (default: 'percent_delta') ('percent_delta', 'percent', 'delta', 'deltaps', 'counter').",
                    "value": "$nx_centreon_cisco_interfaces_units_errors$"
                },
                "--units-traffic": {
                    "description": "Units of thresholds for errors/discards (Default: 'percent_delta') ('percent_delta', 'percent', 'delta', 'counter').",
                    "value": "$nx_centreon_cisco_interfaces_units_traffic$"
                },
                "--warning-in-bcast": {
                    "description": "Set warning threshold for in-bcast",
                    "value": "$nx_centreon_cisco_interfaces_warning_in_bcast$"
                },
                "--warning-in-crc": {
                    "description": "Set warning threshold for in-crc",
                    "value": "$nx_centreon_cisco_interfaces_warning_in_crc$"
                },
                "--warning-in-discard": {
                    "description": "Set warning threshold for in-discard",
                    "value": "$nx_centreon_cisco_interfaces_warning_in_discard$"
                },
                "--warning-in-error": {
                    "description": "Set warning threshold for in-error",
                    "value": "$nx_centreon_cisco_interfaces_warning_in_error$"
                },
                "--warning-in-traffic": {
                    "description": "Set warning threshold for in-traffic",
                    "value": "$nx_centreon_cisco_interfaces_warning_in_traffic$"
                },
                "--warning-out-bcast": {
                    "description": "Set warning threshold for out-bcast",
                    "value": "$nx_centreon_cisco_interfaces_warning_out_bcast$"
                },
                "--warning-out-discard": {
                    "description": "Set warning threshold for out-discard",
                    "value": "$nx_centreon_cisco_interfaces_warning_out_discard$"
                },
                "--warning-out-error": {
                    "description": "Set warning threshold for out-error",
                    "value": "$nx_centreon_cisco_interfaces_warning_out_error$"
                },
                "--warning-out-traffic": {
                    "description": "Set warning threshold for out-traffic",
                    "value": "$nx_centreon_cisco_interfaces_warning_out_traffic$"
                },
                "--warning-status": {
                    "description": "Set warning threshold for status. Can used special variables like: %{admstatus}, %{opstatus}, %{duplexstatus}, %{errdisable}, %{display}",
                    "value": "$nx_centreon_cisco_interfaces_warning_status$"
                }
            },
            "command": "/usr/lib/centreon/plugins/centreon_cisco_standard_snmp.pl",
            "fields": [],
            "imports": [
                "nx-ct-centreon-plugin-snmp",
                "nx-ct-centreon-plugin-retention"
            ],
            "methods_execute": "PluginCheck",
            "object_name": "nx-c-centreon-cisco-standard-interfaces",
            "object_type": "object",
            "uuid": "bbb027db-49bc-4d46-8890-e7cea4ff9ed9"
        },
        "nx-c-centreon-cisco-standard-mem": {
            "arguments": {
                "--critical-usage": {
                    "value": "$nx_centreon_cisco_mem_crit$",
                    "order": "3"
                },
                "--mode": {
                    "value": "memory",
                    "order": "1"
                },
                "--warning-usage": {
                    "value": "$nx_centreon_cisco_mem_warn$",
                    "order": "2"
                }
            },
            "command": "/usr/lib/centreon/plugins/centreon_cisco_standard_snmp.pl",
            "fields": [],
            "imports": [
                "nx-ct-centreon-plugin-snmp"
            ],
            "methods_execute": "PluginCheck",
            "object_name": "nx-c-centreon-cisco-standard-mem",
            "object_type": "object",
            "uuid": "7c19a8fd-fd64-46c7-9fa6-c7ee8fdb6ca6"
        }
    }
}