          ],
          "hide": false,
          "measurement": "/^$command$/",
          "orderByTime": "ASC",
          "policy": "default",
          "query": "SELECT mean(\"value\") FROM /^$command$/ WHERE (\"hostname\" =~ /^$hostname$/ AND \"service\" =~ /^$service$/ AND \"metric\"::tag =~ /^voltage_.*/) AND $timeFilter GROUP BY time($__interval), \"metric\" fill(null)",
          "rawQuery": true,
          "refId": "A",
          "resultFormat": "time_series",
          "select": [
            [
              {
                "params": [
                  "value"
                ],
                "type": "field"
              },
              {
                "params": [],
                "type": "mean"
              }
            ]
          ],
          "tags": [
            {
              "key": "hostname",
              "operator": "=~",
              "value": "/^$hostname$/"
            },
            {
              "condition": "AND",
              "key": "service",
              "operator": "=~",
              "value": "/^$service$/"
            },
            {
              "condition": "AND",
              "key": "metric::tag",
              "operator": "=",
              "value": "USED"
            }
          ]
        }
      ],
      "title": "$service - Temperature - Voltage",
      "transformations": [
        {
          "id": "renameByRegex",
          "options": {
            "regex": "(temp_(.*))",
            "renamePattern": "$2  (°C)"
          }
        },
        {
          "id": "renameByRegex",
          "options": {
            "regex": "(voltage_(.*))",
            "renamePattern": "$2 (V)"
          }
        }
      ],
