      "targets": [
        {
          "alias": "[[tag_metric]]",
          "datasource": {
            "type": "influxdb"
          },
          "groupBy": [
            {
              "params": [
                "$__interval"
              ],
              "type": "time"
            },
            {
              "params": [
                "metric"
              ],
              "type": "tag"
            },
            {
              "params": [
                "null"
              ],
              "type": "fill"
            }
          ],
          "hide": false,
          "measurement": "/^$command$/",
          "orderByTime": "ASC",
          "policy": "default",
          "query": "SELECT mean(\"value\") FROM /^$command$/ WHERE (\"hostname\" =~ /^$hostname$/ AND \"service\" =~ /^$service$/ AND \"metric\"::tag =~ /^temp_.*/) AND $timeFilter GROUP BY time($__interval), \"metric\" fill(null)",
          "rawQuery": true,
          "refId": "VALUE",
          "resultFormat": "time_series",
          "select": [
            [
              {
                "params": [
                  "value"
                ],
                "type": "field"
              },
              {
                "params": [],
                "type": "mean"
              }
            ]
          ],
          "tags": [
            {
              "key": "hostname",
              "operator": "=~",
              "value": "/^$hostname$/"
            },
            {
              "condition": "AND",
              "key": "service",
              "operator": "=~",
              "value": "/^$service$/"
            },
            {
              "condition": "AND",
              "key": "metric::tag",
              "operator": "=",
              "value": "USED"
            }
          ]
        },
        {
          "alias": "[[tag_metric]]",
          "datasource": {
            "type": "influxdb"
          },
          "groupBy": [
            {
              "params": [
                "$__interval"
              ],
