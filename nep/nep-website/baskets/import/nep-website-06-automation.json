{
    "ImportSource": {
        "nx-is-webserver-websites": {
            "description": "Gets the list of hosted Websites from the Webservers defined inside Director.",
            "key_column": "object_name",
            "modifiers": [
                {
                    "description": "Skip all disabled objects",
                    "priority": "1",
                    "property_name": "disabled",
                    "provider_class": "Icinga\\Module\\Director\\PropertyModifier\\PropertyModifierRejectOrSelect",
                    "settings": {
                        "filter_method": "is_true",
                        "policy": "reject"
                    },
                    "target_property": null
                },
                {
                    "description": null,
                    "priority": "2",
                    "property_name": "vars.nx_implements_webserver",
                    "provider_class": "Icinga\\Module\\Director\\PropertyModifier\\PropertyModifierMakeBoolean",
                    "settings": {
                        "filter_method": "is_true",
                        "on_invalid": "null",
                        "policy": "keep"
                    },
                    "target_property": "is_webserver"
                },
                {
                    "description": "Keep only objects that are webservers (literally, implements the webserver ht)",
                    "priority": "3",
                    "property_name": "is_webserver",
                    "provider_class": "Icinga\\Module\\Director\\PropertyModifier\\PropertyModifierRejectOrSelect",
                    "settings": {
                        "filter_method": "is_true",
                        "policy": "keep"
                    },
                    "target_property": null
                },
                {
                    "description": "Set hosting webserver",
                    "priority": "4",
                    "property_name": "object_name",
                    "provider_class": "Icinga\\Module\\Nep\\ProvidedHook\\Director\\PropertyModifier\\PropertyModifierCopy",
                    "settings": {},
                    "target_property": "server_name"
                },
                {
                    "description": "Convert to array (of 1 element)",
                    "priority": "5",
                    "property_name": "server_name",
                    "provider_class": "Icinga\\Module\\Director\\PropertyModifier\\PropertyModifierSplit",
                    "settings": {
                        "delimiter": "|",
                        "when_empty": "null"
                    },
                    "target_property": "parent_hosts"
                },
                {
                    "description": "Provide the default HTTP Port for the current webserver",
                    "priority": "8",
                    "property_name": "vars.nx_webserver_default_http_port",
                    "provider_class": "Icinga\\Module\\Nep\\ProvidedHook\\Director\\PropertyModifier\\PropertyModifierCopy",
                    "settings": {},
                    "target_property": "default_http_port"
                },
                {
                    "description": "Provide the default HTTPS Port for the current webserver",
                    "priority": "11",
                    "property_name": "vars.nx_webserver_default_https_port",
                    "provider_class": "Icinga\\Module\\Nep\\ProvidedHook\\Director\\PropertyModifier\\PropertyModifierCopy",
                    "settings": {},
                    "target_property": "default_https_port"
                },
                {
                    "description": "Extract the list of all hosted websites",
                    "priority": "12",
                    "property_name": "vars.nx_website_hosted_websites",
                    "provider_class": "Icinga\\Module\\Director\\PropertyModifier\\PropertyModifierArrayToRow",
                    "settings": {
                        "on_empty": "reject"
                    },
                    "target_property": "site_url"
                },
                {
                    "description": "Get access protocol from URL",
                    "priority": "13",
                    "property_name": "site_url",
                    "provider_class": "Icinga\\Module\\Director\\PropertyModifier\\PropertyModifierParseURL",
                    "settings": {
                        "on_failure": "null",
                        "pattern": "\/^(HTTP|https):\\\/\\\/(.*)\/",
                        "replacement": "$1",
                        "url_component": "scheme"
                    },
                    "target_property": "site_schema"
                },
                {
                    "description": "Get HOST (host header) from URL",
                    "priority": "14",
                    "property_name": "site_url",
                    "provider_class": "Icinga\\Module\\Director\\PropertyModifier\\PropertyModifierParseURL",
                    "settings": {
                        "on_failure": "null",
                        "url_component": "host"
                    },
                    "target_property": "site_host"
                },
                {
                    "description": "Get TCP Port from URL",
                    "priority": "15",
                    "property_name": "site_url",
                    "provider_class": "Icinga\\Module\\Director\\PropertyModifier\\PropertyModifierParseURL",
                    "settings": {
                        "on_failure": "null",
                        "url_component": "port"
                    },
                    "target_property": "site_port"
                },
                {
                    "description": "Get URI from URL",
                    "priority": "16",
                    "property_name": "site_url",
                    "provider_class": "Icinga\\Module\\Director\\PropertyModifier\\PropertyModifierParseURL",
                    "settings": {
                        "on_failure": "null",
                        "url_component": "path"
                    },
                    "target_property": "site_path"
                },
                {
                    "description": "Get QUERY from URL",
                    "priority": "17",
                    "property_name": "site_url",
                    "provider_class": "Icinga\\Module\\Director\\PropertyModifier\\PropertyModifierParseURL",
                    "settings": {
                        "on_failure": "null",
                        "url_component": "query"
                    },
                    "target_property": "site_query"
                },
                {
                    "description": null,
                    "priority": "18",
                    "property_name": "website_schema",
                    "provider_class": "Icinga\\Module\\Director\\PropertyModifier\\PropertyModifierLowercase",
                    "settings": {},
                    "target_property": null
                },
                {
                    "description": null,
                    "priority": "19",
                    "property_name": "object_name",
                    "provider_class": "Icinga\\Module\\Director\\PropertyModifier\\PropertyModifierCombine",
                    "settings": {
                        "pattern": "${object_name}_${site_schema}:\/\/${site_host}"
                    },
                    "target_property": "object_name"
                },
                {
                    "description": null,
                    "priority": "20",
                    "property_name": "object_name",
                    "provider_class": "Icinga\\Module\\Director\\PropertyModifier\\PropertyModifierLowercase",
                    "settings": {},
                    "target_property": null
                },
                {
                    "description": null,
                    "priority": "21",
                    "property_name": "default_http_port",
                    "provider_class": "Icinga\\Module\\Nep\\ProvidedHook\\Director\\PropertyModifier\\PropertyModifierCoalesce",
                    "settings": {
                        "value": "80"
                    },
                    "target_property": null
                },
                {
                    "description": null,
                    "priority": "22",
                    "property_name": "default_https_port",
                    "provider_class": "Icinga\\Module\\Nep\\ProvidedHook\\Director\\PropertyModifier\\PropertyModifierCoalesce",
                    "settings": {
                        "value": "443"
                    },
                    "target_property": null
                }
            ],
            "originalId": "2",
            "provider_class": "Icinga\\Module\\Director\\Import\\ImportSourceDirectorObject",
            "settings": {
                "object_class": "host",
                "object_type": "",
                "resolved": "y",
                "resource": "director"
            },
            "source_name": "nx-is-webserver-websites"
        }
    },
    "SyncRule": {
        "nx-sr-webserver-websites": {
            "description": "Creates and\/or deletes HO representing each one of the Websites hosted by all Webservers defined in Director. Changes to HO are ignored. Manually disabled HO will remain disabled.\r\nTo restore a HO to its original state, just delete it and re-run this automation.",
            "filter_expression": null,
            "object_type": "host",
            "originalId": "2",
            "properties": [
                {
                    "destination_field": "object_name",
                    "filter_expression": null,
                    "merge_policy": "override",
                    "priority": "1",
                    "source": "nx-is-webserver-websites",
                    "source_expression": "${object_name}"
                },
                {
                    "destination_field": "import",
                    "filter_expression": null,
                    "merge_policy": "override",
                    "priority": "2",
                    "source": "nx-is-webserver-websites",
                    "source_expression": "nx-ht-status-http"
                },
                {
