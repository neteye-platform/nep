{
    "Command": {
        "nx-c-check-smtp-send": {
            "arguments": {
                "--body": {
                    "description": "Body of the message",
                    "value": "$smtp_body$"
                },
                "--header": {
                    "description": "Header",
                    "value": "$smtp_header$"
                },
                "--mailfrom": {
                    "description": "Sender Address (array)",
                    "repeat_key": true,
                    "value": "$smtp_sender$"
                },
                "--mailto": {
                    "description": "Recipient Address (array)",
                    "repeat_key": true,
                    "value": "$smtp_recipient$"
                },
                "-H": {
                    "description": "Hostname",
                    "value": "$smtp_server$"
                },
                "-c": {
                    "description": "Critical Value (in sec)",
                    "value": "$smtp_critical$"
                },
                "-p": {
                    "description": "Port",
                    "value": "$smtp_port$"
                },
                "-w": {
                    "description": "Warning Value (in sec)",
                    "value": "$smtp_warning$"
                }
            },
            "command": "PluginContribDir + \/check_smtp_send",
            "disabled": false,
            "fields": [],
            "imports": [],
            "is_string": null,
            "methods_execute": "PluginCheck",
            "object_name": "nx-c-check-smtp-send",
            "object_type": "object",
            "timeout": null,
            "vars": {
                "smtp_server": "$host.address$"
            },
            "zone": null
        },
        "nx-c-check-imap-receive": {
            "arguments": {
                "--imap-retries": {
                    "description": "Retries",
                    "value": "$imap_retries$"
                },
                "--ssl": {
                    "description": "Enable SSL",
                    "set_if": "$imap_ssl$",
                    "set_if_format": "string"
                },
                "-H": {
                    "description": "Hostname",
                    "value": "$host.address$"
                },
                "-P": {
                    "description": "Password",
                    "value": "$imap_password$"
                },
                "-U": {
                    "description": "Username",
                    "value": "$imap_user$"
                },
                "-c": {
                    "description": "Critical Value (in sec)",
                    "value": "$imap_critical$"
                },
                "-p": {
                    "description": "Port",
                    "value": "$imap_port$"
                },
                "-s": {
                    "description": "Header (array)",
                    "repeat_key": true,
                    "value": "$imap_header$"
                },
                "-w": {
                    "description": "Warning Value (in sec)",
                    "value": "$imap_warning$"
                }
            },
            "command": "PluginContribDir + \/check_imap_receive",
            "disabled": false,
            "fields": [],
            "imports": [],
            "is_string": null,
            "methods_execute": "PluginCheck",
            "object_name": "nx-c-check-imap-receive",
            "object_type": "object",
            "timeout": null,
            "vars": {},
            "zone": null
        }
    }
}