                "--mode": "memory",
                "--no-swap": {
                    "description": "Threshold if no active swap (default: 'critical').",
                    "value": "$nx_centreon_pfsense_mem_no_swap$"
                },
                "--swap": {
                    "description": "Check swap also.",
                    "set_if": "$nx_centreon_pfsense_mem_swap$",
                    "set_if_format": "string"
                },
                "--warning": {
                    "description": "Warning threshold in percent.",
                    "value": "$nx_centreon_pfsense_mem_warning$"
                },
                "--warning-swap": {
                    "description": "Warning threshold in percent.",
                    "value": "$nx_centreon_pfsense_mem_warning_swap$"
                }
            },
            "command": "/usr/lib/centreon/plugins/centreon_pfsense.pl",
            "fields": [],
            "imports": [
                "nx-ct-centreon-plugin-snmp"
            ],
            "methods_execute": "PluginCheck",
            "object_name": "nx-c-centreon-pfsense-memory",
            "object_type": "object"
        },
        "nx-c-centreon-pfsense-swap": {
