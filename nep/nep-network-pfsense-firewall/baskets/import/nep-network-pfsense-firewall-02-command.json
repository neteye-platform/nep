{
  "Command": {
        "nx-c-centreon-pfsense-cpu": {
            "arguments": {
                "--critical-average": {
                    "description": "Critical threshold average CPU utilization.",
                    "value": "$nx_centreon_pfsense_cpu_critical_avg$"
                },
                "--critical-core": {
                    "description": "Critical thresholds for each CPU core",
                    "value": "$nx_centreon_pfsense_critical_core$"
                },
                "--filter-counters": {
                    "description": "Only display some counters (regexp can be used). Example to check SSL connections only : --filter-counters='^xxxx|yyyy$'",
                    "value": "$nx_centreon_pfsense_filter_counters$"
                },
                "--mode": "cpu",
                "--warning-average": {
                    "description": "Warning threshold average CPU utilization.",
                    "value": "$nx_centreon_pfsense_cpu_warning_avg$"
                },
                "--warning-core": {
                    "description": "Warning thresholds for each CPU core",
                    "value": "$nx_centreon_pfsense_warning_core$"
                }
            },
            "command": "/usr/lib/centreon/plugins/centreon_pfsense.pl",
            "fields": [],
            "imports": [
                "nx-ct-centreon-plugin-snmp"
            ],
            "methods_execute": "PluginCheck",
            "object_name": "nx-c-centreon-pfsense-cpu",
            "object_type": "object"
        },
        "nx-c-centreon-pfsense-load": {
            "arguments": {
                "--average": {
                    "description": "Load average for the number of CPUs.",
                    "set_if": "$nx_centreon_pfsense_load_avg$",
                    "set_if_format": "string"
                },
                "--critical": {
                    "description": "Critical threshold (1min,5min,15min).",
                    "value": "$nx_centreon_pfsense_load_critical$"
                },
                "--mode": "load",
                "--warning": {
                    "description": "Warning threshold (1min,5min,15min).",
                    "value": "$nx_centreon_pfsense_load_warning$"
                }
            },
            "command": "/usr/lib/centreon/plugins/centreon_pfsense.pl",
            "fields": [],
            "imports": [
                "nx-ct-centreon-plugin-snmp"
            ],
            "methods_execute": "PluginCheck",
            "object_name": "nx-c-centreon-pfsense-load",
            "object_type": "object"
        },
