                {
                    "description": null,
                    "priority": "4",
                    "property_name": "vm_custom_values",
                    "provider_class": "Icinga\\Module\\Director\\PropertyModifier\\PropertyModifierJsonDecode",
                    "settings": {
                        "on_failure": "fail"
                    },
                    "target_property": null
                },
                {
                    "description": null,
                    "priority": "5",
                    "property_name": "ft_enabled",
                    "provider_class": "Icinga\\Module\\Director\\PropertyModifier\\PropertyModifierMakeBoolean",
                    "settings": {
                        "on_invalid": "false"
                    },
                    "target_property": null
                }
            ],
            "originalId": "4",
            "provider_class": "Icinga\\Module\\Director\\Import\\ImportSourceSql",
            "settings": {
                "column_cache": "object_name, vm_uuid_hex, vcenter_uuid_hex, vm_name, system_uuid, vm_hardware_version, vm_tools_version, vm_tools_status, vm_guest_os_version, vm_guest_os_name, vm_guest_address, vm_annotation, vm_custom_values, ft_enabled, vcsa_name",
                "query": "(\r\n\tSELECT\r\n\t\tLOWER(o.object_name) AS object_name,\r\n\t\tHEX(o.uuid) AS vm_uuid_hex,\r\n\t\tHEX(o.vcenter_uuid) AS vcenter_uuid_hex,\r\n\t\to.object_name AS vm_name,\r\n\t\tvm.bios_uuid AS system_uuid,\r\n\t\tvm.version AS vm_hardware_version,\r\n\t\tvm.guest_tools_status AS vm_tools_version,\r\n\t\tvm.guest_tools_running_status AS vm_tools_status,\r\n\t\tvm.guest_full_name AS vm_guest_os_version,\r\n\t\tvm.guest_host_name AS vm_guest_os_name,\r\n\t\tvm.guest_ip_address AS vm_guest_address,\r\n\t\tvm.annotation AS vm_annotation,\r\n\t\tvm.custom_values AS vm_custom_values,\r\n\t\tfalse AS ft_enabled,\r\n\t\tv.name AS vcsa_name\r\n\tFROM\r\n\t\tobject o\r\n\t\tINNER JOIN virtual_machine vm ON vm.uuid = o.uuid AND vm.vcenter_uuid = o.vcenter_uuid\r\n\t\tINNER JOIN vcenter v ON v.instance_uuid = vm.vcenter_uuid\r\n\tWHERE\r\n\t\to.object_type = 'VirtualMachine'\r\n\t\tAND CONCAT(o.vcenter_uuid, '|', o.object_name) IN (\r\n\t\t\tSELECT CONCAT(vcenter_uuid, '|', object_name)\r\n\t\t\tFROM object\r\n\t\t\tWHERE object_type = 'VirtualMachine'\r\n\t\t\tGROUP BY CONCAT(vcenter_uuid, '|', object_name)\r\n\t\t\tHAVING COUNT(*) = 1\r\n\t\t)\r\n)\r\nUNION ALL\r\n(\r\n\tSELECT\r\n\t\tLOWER(CONCAT(o.object_name, '-', HEX(o.uuid))) AS object_name,\r\n\t\tHEX(o.uuid) AS vm_uuid_hex,\r\n\t\tHEX(o.vcenter_uuid) AS vcenter_uuid_hex,\r\n\t\to.object_name AS vm_name,\r\n\t\tvm.bios_uuid AS system_uuid,\r\n\t\tvm.version AS vm_hardware_version,\r\n\t\tvm.guest_tools_status AS vm_tools_version,\r\n\t\tvm.guest_tools_running_status AS vm_tools_status,\r\n\t\tvm.guest_full_name AS vm_guest_os_version,\r\n\t\tvm.guest_host_name AS vm_guest_os_name,\r\n\t\tvm.guest_ip_address AS vm_guest_address,\r\n\t\tvm.annotation AS vm_annotation,\r\n\t\tvm.custom_values AS vm_custom_values,\r\n\t\ttrue AS ft_enabled,\r\n\t\tv.name AS vcsa_name\r\n\tFROM\r\n\t\tobject o\r\n\t\tINNER JOIN virtual_machine vm ON vm.uuid = o.uuid AND vm.vcenter_uuid = o.vcenter_uuid\r\n\t\tINNER JOIN vcenter v ON v.instance_uuid = vm.vcenter_uuid\r\n\tWHERE\r\n\t\to.object_type = 'VirtualMachine'\r\n\t\tAND CONCAT(o.vcenter_uuid, '|', o.object_name) IN (\r\n\t\t\tSELECT CONCAT(vcenter_uuid, '|', object_name)\r\n\t\t\tFROM object\r\n\t\t\tWHERE object_type = 'VirtualMachine'\r\n\t\t\tGROUP BY CONCAT(vcenter_uuid, '|', object_name)\r\n\t\tHAVING COUNT(*) > 1\r\n\t)\r\n)",
                "resource": "vspheredb"
            },
            "source_name": "nx-is-vmd-virtual-machines"
        }

