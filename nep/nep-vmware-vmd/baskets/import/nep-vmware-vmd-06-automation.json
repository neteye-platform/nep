                "query": "SELECT\r\n\tHEX(o.uuid) AS datastore_uuid_hex,\r\n\tHEX(o.vcenter_uuid) AS vcenter_uuid_hex,\r\n\to.object_name AS datastore_name,\r\n\tv.name AS vcsa_name\t\r\nFROM\r\n\tobject o\r\n\tINNER JOIN vcenter v ON v.instance_uuid = o.vcenter_uuid\r\nWHERE o.object_type = 'Datastore'",
