        "nx-is-vmd-virtual-machines": {
            "description": null,
            "key_column": "object_name",
            "modifiers": [
                {
                    "description": null,
                    "priority": "2",
                    "property_name": "vcsa_name",
                    "provider_class": "Icinga\\Module\\Director\\PropertyModifier\\PropertyModifierLowercase",
