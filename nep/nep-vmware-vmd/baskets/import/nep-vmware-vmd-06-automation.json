            "settings": {
                "column_cache": "host_uuid_hex, vcenter_uuid_hex, host_name, system_uuid, host_api_version, host_product_name, host_vendor, host_model, host_service_tag, vcsa_name",
                "query": "SELECT\r\n\tHEX(o.uuid) AS host_uuid_hex,\r\n\tHEX(o.vcenter_uuid) AS vcenter_uuid_hex,\r\n\to.object_name AS host_name,\r\n\ths.sysinfo_uuid AS system_uuid,\r\n\ths.product_api_version AS host_api_version,\r\n\ths.product_full_name AS host_product_name,\r\n\ths.sysinfo_vendor AS host_vendor,\r\n\ths.sysinfo_model AS host_model,\r\n\ths.service_tag AS host_service_tag,\r\n\tv.name AS vcsa_name\r\nFROM\r\n\tobject o\r\n\tINNER JOIN host_system hs ON hs.uuid = o.uuid AND hs.vcenter_uuid = o.vcenter_uuid\r\n\tINNER JOIN vcenter v ON v.instance_uuid = hs.vcenter_uuid\r\nWHERE\r\n\to.object_type = 'HostSystem'",
                "resource": "vspheredb"
            },
            "source_name": "nx-is-vmd-host-system"
        },
