                "--hostname": "$mssql_health_hostname$",
                "--mode": "$mssql_health_mode$",
                "--name": "$mssql_health_name$",
                "--name2": "$mssql_health_name2$",
                "--password": "$mssql_health_password$",
                "--port": "$mssql_health_port$",
                "--regexp": {
                    "set_if": "$mssql_health_regexp$",
