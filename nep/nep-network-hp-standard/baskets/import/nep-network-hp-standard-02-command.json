            ],
            "methods_execute": "PluginCheck",
            "object_name": "nx-c-centreon-hp-standard-cpu",
            "object_type": "object"
        },
        "nx-c-centreon-hp-standard-hardware": {
            "arguments": {
                "--component": {
                    "description": "Which component to check (default: '.*'). Can be: 'fan', 'psu','other', 'unknown', 'sensor', 'chassis', 'backplane', 'container', 'module', 'port', 'stack', 'cpu'.",
                    "value": "$nx_centreon_plugin_component$"
                },
                "--critical": {
                    "description": "Set critical threshold for 'temperature' (syntax: type,regexp,threshold) Example: --critical='temperature,.*,45'",
                    "value": "$nx_centreon_plugin_snmp_crit$"
                },
                "--filter": {
                    "description": "Exclude the items given as a comma-separated list (example: --filter=fan --filter=psu). You can also exclude items from specific instances: --filter=fan,101",
                    "value": "$nx_centreon_plugin_filter_sensor$"
                },
                "--mode": "hardware",
                "--warning": {
                    "description": "Set warning threshold for 'temperature' (syntax: type,regexp,threshold) Example: --warning='temperature,.*,40'",
                    "value": "$nx_centreon_plugin_snmp_warn$"
                }
            },
            "command": "/usr/lib/centreon/plugins/centreon_hp_standard_snmp.pl",
            "fields": [],
            "imports": [
                "nx-ct-centreon-plugin-snmp",
                "nx-ct-centreon-plugin-retention"
            ],
            "methods_execute": "PluginCheck",
            "object_name": "nx-c-centreon-hp-standard-hardware",
            "object_type": "object"
        },
        "nx-c-centreon-hp-standard-interfaces": {
            "arguments": {
                "--add-errors": {
                    "description": "Check interface errors."
                },
                "--add-traffic": {
                    "description": "Check interface traffic."
                },
                "--critical-in-traffic": {
                    "description": "Critical threshold",
                    "value": "$nx_centreon_plugin_snmp_crit$"
                },
                "--filter-perfdata": {
                    "description": "Filter perfdata that match the regexp. Example: adding --filter-perfdata='avg' will remove all metrics that do not contain 'avg' from performance data.",
                    "value": "traffic*"
                },
                "--interface": {
                    "description": "Set the interface (number expected) example: 1,2,... (empty means 'check all interfaces')",
                    "value": "$nx_centreon_plugin_snmp_interface$"
                },
                "--mode": {
                    "description": "Check interfaces.",
                    "value": "interfaces"
                },
                "--name": {
                    "description": "Allows you to define the interface (in option --interface) by name instead of OID index. The name matching mode supports regular expressions."
                },
                "--speed-in": {
                    "description": "Set interface speed for incoming traffic (in Mb).",
                    "value": "$nx_centreon_plugin_snmp_speed$"
                },
                "--units-traffic": {
                    "description": "Units of thresholds for the traffic (Default: 'percent_delta') ('percent_delta', 'bps', 'counter').",
                    "value": "$nx_centreon_plugin_snmp_unit$"
                },
                "--warning-in-traffic": {
                    "description": "Warning threshold",
                    "value": "$nx_centreon_plugin_snmp_warn$"
                }
            },
            "command": "/usr/lib/centreon/plugins/centreon_hp_standard_snmp.pl",
            "fields": [],
            "imports": [
                "nx-ct-centreon-plugin-snmp",
                "nx-ct-centreon-plugin-retention"
            ],
            "methods_execute": "PluginCheck",
            "object_name": "nx-c-centreon-hp-standard-interfaces",
            "object_type": "object"
        },
        "nx-c-centreon-hp-standard-memory": {
            "arguments": {
                "--critical-usage": {
                    "description": "Critical threshold (in percent).",
                    "value": "$nx_centreon_plugin_snmp_crit$"
                },
                "--mode": {
                    "description": "Check memory usage (hpNetSwitch.mib).",
                    "value": "memory"
                },
                "--warning-usage": {
                    "description": "Warning threshold (in percent).",
                    "value": "$nx_centreon_plugin_snmp_warn$"
                }
            },
            "command": "/usr/lib/centreon/plugins/centreon_hp_standard_snmp.pl",
            "fields": [],
            "imports": [
                "nx-ct-centreon-plugin-snmp"
            ],
            "methods_execute": "PluginCheck",
            "object_name": "nx-c-centreon-hp-standard-memory",
            "object_type": "object"
        }
    }
