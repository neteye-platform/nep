{
    "Command": {
        "nx-c-centreon-hp-standard-cpu": {
            "arguments": {
                "--critical-usage": {
                    "description": "Critical threshold.",
                    "value": "$nx_centreon_plugin_snmp_crit$"
                },
                "--mode": {
                    "description": "Check cpu usage (hpSwitchStat.mib).",
                    "value": "cpu"
                },
                "--warning-usage": {
                    "description": "Warning threshold.",
                    "value": "$nx_centreon_plugin_snmp_warn$"
                }
            },
            "command": "/usr/lib/centreon/plugins/centreon_hp_standard_snmp.pl",
            "fields": [],
