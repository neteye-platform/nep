    "CommandTemplate": {
        "nx-ct-sap-check-hana": {
            "arguments": {
                "--crit": {
                    "description": "critical threshold",
                    "set_if": "$nx_sap_hana_crit$",
                    "set_if_format": "string",
                    "value": "$nx_sap_hana_crit$"
                },
                "--function": {
                    "description": "function to execute",
                    "skip_key": false,
                    "value": "$nx_sap_hana_function$"
                },
                "--host": {
                    "description": "IP-address of host",
                    "skip_key": false,
                    "value": "$host.address$"
                },
                "--lookback": {
                    "description": "lookback-time for functions like last_backup",
                    "set_if": "$nx_sap_hana_lookback$",
                    "set_if_format": "string",
                    "value": "$nx_sap_hana_lookback$"
                },
                "--pass": {
                    "description": "Password for SQL-connect",
                    "skip_key": false,
                    "value": "$nx_sap_hana_password$"
                },
                "--port": {
                    "description": "SAP HANA Tenant SQL-Port",
                    "skip_key": false,
                    "value": "$nx_sap_hana_port$"
                },
                "--sid": {
                    "description": "SID of HANA Datanase Instance",
                    "skip_key": false,
                    "value": "$nx_sap_hana_sid$"
                },
                "--user": {
                    "description": "User for SQL-connect",
                    "skip_key": false,
                    "value": "$nx_sap_hana_user$"
                },
                "--warn": {
                    "description": "warning threshold",
                    "set_if": "$nx_sap_hana_warn$",
                    "set_if_format": "string",
                    "value": "$nx_sap_hana_warn$"
                }
            },
            "command": "PluginContribDir + /check_hana.sh",
            "fields": [],
            "methods_execute": "PluginCheck",
            "object_name": "nx-ct-sap-check-hana",
            "object_type": "template",
            "timeout": 60,
            "uuid": "46847010-cf9e-475b-95d1-bce9a6d62bd7"
        }
    }
}