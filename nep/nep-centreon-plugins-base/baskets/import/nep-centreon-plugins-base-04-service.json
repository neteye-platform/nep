    "Datafield": {
        "193": {
            "uuid": "288ddaa7-6294-48e7-b6f8-cf28363aca06",
            "varname": "nx_centreon_plugin_change_exit",
            "caption": "[NX] Change Exit code",
            "description": "Replace an exit code with one of your choice. Eg: adding --change-exit=unknown=critical will result in a CRITICAL state instead of an UNKNOWN state.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeDatalist",
            "format": null,
            "settings": {
                "behavior": "strict",
                "data_type": "array",
                "datalist": "[NX] Centreon Exit code changes List"
            },
            "category": "Centreon plugin Output management"
        },
        "194": {
            "uuid": "6e574b3d-b49f-4143-b7a9-68c948bc2345",
            "varname": "nx_centreon_plugin_change_long_output",
            "caption": "[NX] Change Long output",
            "description": "Modify the short/long output that is returned by the plugin. Syntax: --change-short-output=pattern~replacement~modifier Most commonly used modifiers are i (case insensitive) and g (replace all occurrences). Eg: adding --change-short-output='OK~Up~gi' will replace all occurrences of 'OK', 'ok', 'Ok' or 'oK' with 'Up'",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeArray",
            "format": null,
            "settings": {},
            "category": "Centreon plugin Output management"
        },
        "195": {
            "uuid": "cc7d4dcd-019a-49bc-ae62-74b49b9ce9ad",
            "varname": "nx_centreon_plugin_change_perfdata",
            "caption": "[NX] Change Performance data",
            "description": "Change or extend perfdata. Syntax: --extend-perfdata=searchlabel,newlabel,target[,[newuom],[min],[m ax]]",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeArray",
            "format": null,
            "settings": {},
            "category": "Centreon plugin Output management"
        },
        "196": {
            "uuid": "f1ce31fd-9eb9-419b-afa4-6af01a428c80",
            "varname": "nx_centreon_plugin_change_short_output",
            "caption": "[NX] Change Short output",
            "description": "Modify the short/long output that is returned by the plugin. Syntax: --change-short-output=pattern~replacement~modifier Most commonly used modifiers are i (case insensitive) and g (replace all occurrences). Eg: adding --change-short-output='OK~Up~gi' will replace all occurrences of 'OK', 'ok', 'Ok' or 'oK' with 'Up'",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeArray",
            "format": null,
            "settings": {},
            "category": "Centreon plugin Output management"
        },
        "163": {
            "uuid": "dfc06b70-0679-4b11-9ba6-194b734bf3f2",
            "varname": "nx_centreon_plugin_convert_args",
            "caption": "[NX] Convert arguments",
            "description": "Replace a pattern in the provided arguments. Useful to bypass forbidden characters. E.g.: when a password transmitted via the NRPE protocol contains '!' (which is interpreted as a separator), you can send '##' instead of the '!' and the plugin will replace '##' with '!', using the --convert-args='##,\\x21' option.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "category": "Centreon plugin (advanced)"
        },
        "207": {
            "uuid": "9f36e743-0389-4d46-9802-f949f7924479",
            "varname": "nx_centreon_plugin_debug",
            "caption": "[NX] Enable debug output",
            "description": "Display debug messages",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeBoolean",
            "format": null,
            "settings": {},
            "category": "Centreon plugin Output management"
        },
        "164": {
            "uuid": "2e5d2e09-3660-4534-973b-54fe2f0fd4ea",
            "varname": "nx_centreon_plugin_environment",
            "caption": "[NX] Environment variables",
            "description": "Define environment variables for the script (set them in the execution environment before running it for better performance)",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "category": "Centreon plugin (advanced)"
        },
        "198": {
            "uuid": "8e121902-93ba-4157-9ea9-33813a00a9c3",
            "varname": "nx_centreon_plugin_explode_perfdata_max",
            "caption": "[NX] Create MAX metrics",
            "description": "Create a new metric for each metric that comes with a maximum limit. The new metric will be named identically with a '_max' suffix). Eg: it will split 'used_prct'=26.93%;0:80;0:90;0;100 into 'used_prct'=26.93%;0:80;0:90;0;100 'used_prct_max'=100%;;;;",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "category": "Centreon plugin Output management"
        },
        "199": {
            "uuid": "69237a07-4e2c-436d-aa89-8c4fcc78ee91",
            "varname": "nx_centreon_plugin_extend_perfdata",
            "caption": "[NX] Extend Performance data",
            "description": "Change or extend perfdata. Syntax: --extend-perfdata=searchlabel,newlabel,target[,[newuom],[min],[max]]",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "category": "Centreon plugin Output management"
        },
        "200": {
            "uuid": "ac123117-5787-4c13-b1a4-f59966f96dac",
            "varname": "nx_centreon_plugin_extend_perfdata_group",
            "caption": "[NX] Create aggregated metrics",
            "description": "Add new aggregated metrics (min, max, average or sum) for groups of metrics defined by a regex match on the metrics' names.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "category": "Centreon plugin Output management"
        },
        "201": {
            "uuid": "410a8cd6-f88f-4af2-8c5d-b862599bdf82",
            "varname": "nx_centreon_plugin_filter_perfdata",
            "caption": "[NX] Filter Performance data",
            "description": "Filter perfdata that match the regexp. Eg: adding --filter-perfdata='avg' will remove all metrics that do not contain 'avg' from performance data.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "category": "Centreon plugin Output management"
        },
        "202": {
            "uuid": "ce43941f-283c-4c10-91ba-87c0dc938187",
            "varname": "nx_centreon_plugin_filter_perfdata_adv",
            "caption": "[NX] FIlter Performance data (adv)",
            "description": "Filter perfdata based on a \"if\" condition using the following variables: label, value, unit, warning, critical, min, max. Variables must be written either %{variable} or %(variable). Eg: adding --filter-perfdata-adv='not (%(value) == 0 and %(max) eq \"\")' will remove all metrics whose value equals 0 and that don't have a maximum value.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "category": "Centreon plugin Output management"
        },
        "197": {
            "uuid": "278aae3d-2541-4a4f-bde8-9a759e1c3571",
            "varname": "nx_centreon_plugin_filter_uom",
            "caption": "[NX] Filter UOM",
            "description": "Mask the units when they don't match the given regular expression",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
