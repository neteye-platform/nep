                "--critical-in-traffic": {
                    "description": "Thresholds.",
                    "value": "$nx_centreon_plugin_snmp_crit$",
                    "order": "8"
                },
                "--interface": {
                    "description": "Set the interface (number expected) ex: 1,2,... (empty means 'check all interfaces').",
