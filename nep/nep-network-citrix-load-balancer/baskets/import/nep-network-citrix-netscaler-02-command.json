                    "set_if_format": "string"
                },
                "--snmp-retries": {
                    "description": "Maximum number of retries (default: 5).",
                    "value": "$nx_centreon_plugin_snmp_snmp_retries$"
                },
                "--snmp-timeout": {
                    "description": "Time to wait before sending the request again if no reply has been received, in seconds (default: 1). See also --snmp-retries.",
                    "value": "$nx_centreon_plugin_snmp_snmp_timeout$"
                },
                "--statefile-dir": {
                    "description": "Directory for statefile (Default: '\\/var\\/lib\\/centreon\\/centplugins')",
