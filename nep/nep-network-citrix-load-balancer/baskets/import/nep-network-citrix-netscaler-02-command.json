                "--critical-servers": {
                    "value": "$nx_centreon_plugin_snmp_crit$",
                    "order": "3"
                },
                "--filter-name": {
                    "description": "Filter by name (can be a regexp).",
                    "value": "$nx_centreon_plugin_snmp_filter-name$"
                },
                "--filter-type": {
                    "description": "Filter by type (can be a regexp).",
                    "value": "$nx_centreon_plugin_snmp_filter_type$"
                },
                "--mode": {
                    "value": "vserver-status",
                    "order": "1"
                },
                "--snmp-autoreduce": {
                    "description": "Progressively reduce the number of requested OIDs in bulk mode. Use it in case of SNMP errors (By default, the number is divided by 2).",
