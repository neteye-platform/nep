        "nx-c-centreon-citrix-netscaler-ha-state": {
            "arguments": {
                "--critical-ha-status": {
                    "description": "Define the conditions to match for the status to be CRITICAL. (Default: '%{ha_status} =~ /down|partialFail|monitorFail|completeFail|partialFailSsl|routem onitorFail/i'). Can use special variables like: %{ha_status}, %{ha_mode}",
                    "value": "$nx_centreon_netscaler_ha_critical_ha_status$"
                },
                "--critical-peer-status": {
                    "description": "Define the conditions to match for the status to be CRITICAL. (Default: ''). Can use special variables like: %{peer_status}",
                    "value": "$nx_centreon_netscaler_ha_critical_peer_status$"
                },
                "--mode": "ha-state",
                "--unknown-ha-status": {
                    "description": "Define the conditions to match for the status to be UNKNOWN. (Default: '%{ha_status} =~ /unknown/i'). Can use special variables like: %{ha_status}",
                    "value": "$nx_centreon_netscaler_ha_unkown_ha_status$"
                },
                "--unknown-peer-status": {
                    "description": "Define the conditions to match for the status to be UNKNOWN. (Default: '%{peer_status} =~ /unknown/i'). Can use special variables like: %{peer_status}, %{ha_mode}",
                    "value": "$nx_centreon_netscaler_ha_unknown_peer_status$"
                },
                "--warning-ha-status": {
                    "description": "Define the conditions to match for the status to be WARNING. (Default: ''). Can use special variables like: %{ha_status}, %{ha_mode}",
                    "value": "$nx_centreon_netscaler_ha_warning_ha_status$"
                },
                "--warning-peer-status": {
                    "description": "Define the conditions to match for the status to be WARNING. (Default: ''). Can use special variables like: %{peer_status}",
                    "value": "$nx_centreon_netscaler_ha_warning_peer_status$"
                }
            },
