        "--warning-sbc-calls-active-outbound": {
          "description": "Set warning threshold for sbc-calls-active-outbound",
          "value": "$nx_centreon_audiocodes_sbc_calls_warning_active_outbound$"
        },
        "--warning-sbc-calls-duration-average": {
          "description": "Set warning threshold for sbc-calls-duration-average",
          "value": "$nx_centreon_audiocodes_sbc_calls_warning_duration_average$"
        },
        "--warning-sbc-calls-established-inbound": {
          "description": "Set warning threshold for sbc-calls-established-inbound",
          "value": "$nx_centreon_audiocodes_sbc_calls_warning_established_inbound$"
        },
        "--warning-sbc-calls-established-outbound": {
          "description": "Set warning threshold for sbc-calls-established-outbound",
          "value": "$nx_centreon_audiocodes_sbc_calls_warning_established_outbound$"
        },
        "--warning-sbc-calls-notestablished-inbound-failed": {
          "description": "Set warning threshold for sbc-calls-notestablished-inbound-failed",
          "value": "$nx_centreon_audiocodes_sbc_calls_warning_notestab_inbound_fail$"
        },
        "--warning-sbc-calls-notestablished-outbound": {
          "description": "Set warning threshold for sbc-calls-notestablished-outbound",
          "value": "$nx_centreon_audiocodes_sbc_calls_warning_nonestab_outbound$"
        },
        "--warning-sbc-sessions-active": {
          "description": "Set warning threshold for sbc-sessions-active",
          "value": "$nx_centreon_audiocodes_sbc_calls_warning_sessions_active$"
        }
      },
      "command": "/usr/lib/centreon/plugins/centreon_audiocodes.pl",
      "fields": null,
      "imports": [
        "nx-ct-centreon-plugin-snmp",
        "nx-ct-centreon-plugin-retention"
      ],
      "methods_execute": "PluginCheck",
      "object_name": "nx-c-centreon-audiocodes-sbc-calls",
      "object_type": "object"
    },
    "nx-c-centreon-audiocodes-trunk-status": {
      "arguments": {
        "--critical-avg-calls": {
          "description": "Set critical threshold for avg-calls",
          "value": "$nx_centreon_audiocodes_trunk_critical_avg_calls$"
        },
        "--critical-count-calls": {
          "description": "Set critical threshold for count-calls",
          "value": "$nx_centreon_audiocodes_trunk_critical_count_calls$"
        },
        "--critical-max-calls": {
          "description": "Set critical threshold for max-calls",
          "value": "$nx_centreon_audiocodes_trunk_critical_max_calls$"
        },
        "--critical-status": {
          "description": "Define the conditions to match for the status to be CRITICAL (default: '%{state} =~ /activated/ and %{alarm} !~ /greenActive/i'). You can use the following variables: %{display}, %{alarm}, %{dchannel}, %{state}",
          "value": "$nx_centreon_audiocodes_critical_status$"
        },
        "--filter-name": {
          "description": "Filter by name (can be a regexp).",
          "value": "$nx_centreon_plugin_snmp_filter-name$"
        },
        "--mode": "trunk-status",
        "--statefile-dir": {
          "description": "Define the cache directory (default: '/var/lib/centreon/centplugins').",
          "value": "$nx_centreon_plugin_retention_statefile_dir$"
        },
        "--warning-avg-calls": {
          "description": "Set warning threshold for avg-calls",
          "value": "$nx_centreon_audiocodes_trunk_warning_avg_calls$"
        },
        "--warning-count-calls": {
          "description": "Set warning threshold for count-calls",
          "value": "$nx_centreon_audiocodes_trunk_warning_count_calls$"
        },
        "--warning-max-calls": {
          "description": "Set warning threshold for max-calls",
          "value": "$nx_centreon_audiocodes_trunk_warning_max_calls$"
        },
        "--warning-status": {
          "description": "Define the conditions to match for the status to be WARNING. You can use the following variables: %{display}, %{alarm}, %{dchannel}, %{state}",
          "value": "$nx_centreon_audiocodes_warning_status$"
        }
      },
      "command": "/usr/lib/centreon/plugins/centreon_audiocodes.pl",
      "fields": null,
      "imports": [
        "nx-ct-centreon-plugin-snmp",
        "nx-ct-centreon-plugin-retention"
      ],
      "methods_execute": "PluginCheck",
      "object_name": "nx-c-centreon-audiocodes-trunk-status",
      "object_type": "object"
    }
  }
}
