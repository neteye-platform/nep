          "value": "$nx_centreon_audiocodes_filter_counters$"
        },
        "--mode": "sbc-calls",
        "--statefile-dir": {
          "description": "Define the cache directory (default: '/var/lib/centreon/centplugins').",
          "value": "$nx_centreon_plugin_retention_statefile_dir$"
        },
        "--warning-sbc-calls-active-inbound": {
          "description": "Set warning threshold for sbc-calls-active-inbound",
          "value": "$nx_centreon_audiocodes_sbc_calls_warning_active_inbound$"
