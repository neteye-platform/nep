        "--critical-sbc-calls-active-outbound": {
          "description": "Set critical threshold for sbc-calls-active-outbound",
          "value": "$nx_centreon_audiocodes_sbc_calls_critical_active_outbound$"
        },
        "--critical-sbc-calls-duration-average": {
          "description": "Set critical threshold for sbc-calls-duration-average",
          "value": "$nx_centreon_audiocodes_sbc_calls_critical_duration_average$"
        },
        "--critical-sbc-calls-established-inbound": {
          "description": "Set critical threshold for sbc-calls-established-inbound",
          "value": "$nx_centreon_audiocodes_sbc_calls_critical_estabilished_inbound$"
        },
        "--critical-sbc-calls-established-outbound": {
          "description": "Set critical threshold for sbc-calls-established-outbound",
          "value": "$nx_centreon_audiocodes_sbc_calls_critical_established_outbound$"
        },
        "--critical-sbc-calls-notestablished-inbound-failed": {
          "description": "Set critical threshold for sbc-calls-notestablished-inbound-failed",
          "value": "$nx_centreon_audiocodes_sbc_calls_critical_notestab_inbound_fail$"
        },
        "--critical-sbc-calls-notestablished-outbound": {
          "description": "Set critical threshold for sbc-calls-notestablished-outbound",
          "value": "$nx_centreon_audiocodes_sbc_calls_critical_notestab_outbound$"
