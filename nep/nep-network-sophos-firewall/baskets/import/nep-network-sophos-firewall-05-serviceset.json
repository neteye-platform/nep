                    "object_type": "object"
                },
                "Memory Usage": {
                    "fields": [],
                    "imports": [
                        "nx-st-agentless-snmp-centreon-cyberoam-memory",
                        "nx-st-type-custom"
                    ],
                    "object_name": "Memory Usage",
                    "object_type": "object"
                },
                "Disk Usage": {
                    "fields": [],
                    "imports": [
                        "nx-st-agentless-snmp-centreon-cyberoam-storage",
                        "nx-st-type-custom"
                    ],
                    "object_name": "Disk Usage",
                    "object_type": "object"
                },
                "Licenses": {
                    "fields": [],
                    "imports": [
                        "nx-st-agentless-snmp-centreon-cyberoam-license",
                        "nx-st-type-custom"
                    ],
                    "object_name": "Licenses",
                    "object_type": "object"
                }
            }
        }
    }
