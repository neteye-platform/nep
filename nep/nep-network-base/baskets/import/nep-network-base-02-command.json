        },
        "nx-c-traceroute": {
            "arguments": {
                "(no key)": {
                    "description": "Target host",
                    "skip_key": true,
                    "value": "$nx_trace_target_host$",
                    "order": "1"
                },
                "(no key.2)": {
                    "description": "Max hop to check",
                    "skip_key": true,
                    "value": "$nx_trace_max_hop$",
                    "order": "2"
                },
                "(no key.3)": {
                    "description": "timeout in sec (default 15)",
                    "skip_key": true,
                    "value": "$nx_trace_timeout$",
                    "order": "3"
                },
                "(no key.4)": {
                    "description": "route1 (master)",
                    "skip_key": true,
                    "value": "$nx_trace_master_route$",
                    "order": "4"
                },
                "(no key.5)": {
                    "description": "route2 (backup)",
                    "skip_key": true,
                    "value": "$nx_trace_backup_route$",
                    "order": "5"
                }
            },
            "command": "PluginContribDir + /check_traceroute",
            "disabled": false,
            "fields": [],
            "imports": [],
            "is_string": null,
            "methods_execute": "PluginCheck",
            "object_name": "nx-c-traceroute",
            "object_type": "object",
            "timeout": null,
            "uuid": "c3e55491-79cd-42c0-8fff-e60e97a3dcc6",
            "vars": {
                "nx_trace_timeout": "15"
            },
            "zone": null
        },
